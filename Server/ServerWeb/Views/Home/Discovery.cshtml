@model IEnumerable<ServerWeb.Models.Song>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? "Khám phá";
    var searchQuery = ViewBag.SearchQuery as string ?? string.Empty;
    var selectedGenre = ViewBag.SelectedGenre as string ?? string.Empty;
    var genres = ViewBag.Genres as List<string> ?? new List<string>();
    var topArtists = ViewBag.TopArtists as List<string> ?? new List<string>();
}

<div class="discovery-page">
    <section class="discovery-hero">
        <div class="hero-copy">
            <span class="hero-label">Khám phá</span>
            <h1>Âm nhạc mới mỗi ngày</h1>
            <p>Khám phá các ca khúc, nghệ sĩ và playlist được tuyển chọn dành riêng cho bạn.</p>
        </div>
        <div class="hero-panel">
            <form action="/Home/Search" method="get" class="search-card">
                <div class="search-field">
                    <i class="fas fa-search"></i>
                    <input type="text" name="query" value="@searchQuery" placeholder="Tìm kiếm tên bài, nghệ sĩ, album, thể loại" />
                </div>
                <div class="search-actions">
                    <select name="genre" onchange="this.form.submit()">
                        <option value="">Tất cả thể loại</option>
                        @foreach (var genre in genres)
                        {
                            if (genre == selectedGenre)
                            {
                                <option value="@genre" selected>@genre</option>
                            }
                            else
                            {
                                <option value="@genre">@genre</option>
                            }
                        }
                    </select>
                    <button type="submit">Tìm kiếm</button>
                </div>
            </form>

            <div class="artist-suggestions-card">
                <div class="suggestions-header">
                    <div>
                        <h3>Nghệ sĩ nổi bật</h3>
                        <p>Gợi ý cho bạn theo xu hướng hiện tại.</p>
                    </div>
                    <span class="tag-count">@topArtists.Count() nghệ sĩ</span>
                </div>
                <div class="artist-tags">
                    @foreach (var artist in topArtists)
                    {
                        <a class="artist-tag" href="@Url.Action("Artist", "Home", new { name = artist })">@artist</a>
                    }
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(searchQuery) || !string.IsNullOrWhiteSpace(selectedGenre))
    {
        <section class="discovery-summary">
            <div class="summary-pill">@Model.Count() kết quả</div>
            <div class="summary-tags">
                @if (!string.IsNullOrWhiteSpace(searchQuery)) { <span>Tìm kiếm: "@searchQuery"</span> }
                @if (!string.IsNullOrWhiteSpace(selectedGenre)) { <span>Thể loại: "@selectedGenre"</span> }
            </div>
        </section>
    }

    <section class="song-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var song in Model)
            {
                <article class="song-card" data-song-id="@song.Id">
                    <div class="cover-wrapper">
                        <img src="@song.CoverPath" alt="@song.Name" />
                        <button class="play-icon" type="button" data-id="@song.Id" aria-label="Play @song.Name">
                            <i class="fas fa-play"></i>
                        </button>
                    </div>
                    <div class="song-info">
                        <h4>@song.Name</h4>
                        <p>@song.Author</p>
                    </div>
                    <div class="song-meta">
                        <span>@song.Album</span>
                        <span>@(song.Duration.TotalHours >= 1 ? song.Duration.ToString(@"h\:mm\:ss") : song.Duration.ToString(@"mm\:ss"))</span>
                    </div>
                </article>
            }
        }
        else
        {
            <div class="empty-state">
                <h3>Không có bài hát nào</h3>
                <p>Thử thay đổi từ khóa tìm kiếm hoặc chọn một thể loại khác.</p>
            </div>
        }
    </section>
</div>

<style>
    .discovery-page {
        padding: 32px 24px;
        max-width: 1280px;
        margin: 0 auto;
        color: #f4f4f8;
    }

    .discovery-hero {
        display: grid;
        grid-template-columns: 1.35fr 1fr;
        gap: 28px;
        align-items: start;
        margin-bottom: 32px;
    }

    .hero-copy {
        padding: 42px 36px;
        background: linear-gradient(180deg, rgba(102, 61, 255, 0.95), rgba(29, 20, 85, 0.95));
        border-radius: 30px;
        box-shadow: 0 28px 80px rgba(17, 10, 56, 0.35);
    }

    .hero-label {
        display: inline-flex;
        padding: 10px 16px;
        border-radius: 999px;
        background: rgba(255,255,255,0.08);
        color: #d3c4ff;
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .hero-copy h1 {
        font-size: clamp(3rem, 2.2rem + 2vw, 4.5rem);
        line-height: 1.02;
        margin: 0;
        max-width: 640px;
    }

    .hero-copy p {
        margin: 20px 0 0;
        color: #d8d4ff;
        font-size: 1.05rem;
        max-width: 620px;
    }

    .hero-panel {
        display: grid;
        gap: 20px;
    }

    .search-card,
    .artist-suggestions-card {
        background: rgba(255,255,255,0.06);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 28px;
        padding: 24px;
    }

    .search-field {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 20px;
        border-radius: 18px;
        background: rgba(255,255,255,0.1);
    }

    .search-field i {
        color: #c7c2ff;
        font-size: 1.1rem;
    }

    .search-field input {
        width: 100%;
        border: none;
        background: transparent;
        color: #ffffff;
        font-size: 1rem;
        outline: none;
    }

    .search-actions {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 16px;
        margin-top: 18px;
    }

    .search-actions select,
    .search-actions button {
        border: none;
        border-radius: 18px;
        padding: 14px 18px;
        font-size: 0.95rem;
    }

    .search-actions select {
        background: rgba(255,255,255,0.08);
        color: #f4f4f8;
        appearance: none;
    }

    .search-actions button {
        background: #7c5dff;
        color: #ffffff;
        cursor: pointer;
        transition: transform 0.2s, background 0.2s;
    }

    .search-actions button:hover {
        transform: translateY(-1px);
        background: #845dff;
    }

    .artist-suggestions-card h3 {
        margin: 0;
        font-size: 1.3rem;
    }

    .artist-suggestions-card p {
        margin: 8px 0 0;
        color: #c6c0ff;
    }

    .suggestions-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 18px;
    }

    .tag-count {
        font-size: 0.9rem;
        color: #9d93ff;
    }

    .artist-tags {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 12px;
    }

    .artist-tag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 16px;
        border-radius: 999px;
        background: rgba(255,255,255,0.08);
        color: #f4f4f8;
        text-decoration: none;
        transition: transform 0.2s, background 0.2s;
    }

    .artist-tag:hover {
        transform: translateY(-1px);
        background: rgba(124,93,255,0.16);
    }

    .discovery-summary {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .summary-pill {
        background: rgba(124,93,255,0.18);
        color: #e8e2ff;
        padding: 10px 18px;
        border-radius: 999px;
        font-weight: 600;
    }

    .summary-tags span {
        display: inline-block;
        color: #cfc9ff;
        margin-right: 14px;
    }

    .song-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
    }

    .song-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 28px;
        overflow: hidden;
        display: grid;
        gap: 16px;
        transition: transform 0.25s, box-shadow 0.25s;
    }

    .song-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 28px 80px rgba(17, 10, 56, 0.25);
    }

    .cover-wrapper {
        position: relative;
        overflow: hidden;
    }

    .cover-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .play-icon {
        position: absolute;
        right: 18px;
        bottom: 18px;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: none;
        background: #7c5dff;
        color: #ffffff;
        display: grid;
        place-items: center;
        cursor: pointer;
        transition: transform 0.2s, background 0.2s;
    }

    .play-icon:hover {
        transform: scale(1.05);
        background: #916bff;
    }

    .song-info {
        padding: 0 20px;
    }

    .song-info h4 {
        margin: 0 0 8px;
        font-size: 1.1rem;
    }

    .song-info p {
        margin: 0;
        color: #bdb8ff;
        font-size: 0.95rem;
    }

    .song-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 0 20px 20px;
        color: #9f98ff;
        font-size: 0.92rem;
    }

    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 56px 24px;
        border: 1px dashed rgba(255,255,255,0.12);
        border-radius: 28px;
        color: #c4bef2;
        background: rgba(255,255,255,0.03);
    }

    .empty-state h3 {
        margin-bottom: 12px;
        font-size: 1.5rem;
    }

    .empty-state p {
        margin: 0;
        color: #a99fe3;
    }

    @@media (max-width: 900px) {
        .discovery-hero {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 660px) {
        .search-actions {
            grid-template-columns: 1fr;
        }

        .hero-copy h1 {
            font-size: 2.5rem;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof openPlayer !== 'function') {
            console.error('openPlayer not available on discovery page');
            return;
        }

        function getDiscoverySongIds() {
            return Array.from(document.querySelectorAll('.song-card[data-song-id]'))
                .map(card => card.dataset.songId) // Keep as string - MongoDB ObjectIds
                .filter(id => id && id !== 'undefined' && id !== 'NaN');
        }

        function playDiscoverySong(songId) {
            const songIds = getDiscoverySongIds();
            if (!songIds.length) {
                console.error('No discovery songs found to play');
                return;
            }
            openPlayer(songId, songIds);
        }

        document.querySelectorAll('.song-card').forEach(card => {
            card.addEventListener('click', function() {
                const songId = this.dataset.songId; // Keep as string
                if (!songId || songId === 'undefined') return;
                playDiscoverySong(songId);
            });
        });

        document.querySelectorAll('.play-icon').forEach(button => {
            button.addEventListener('click', function(event) {
                event.stopPropagation();
                const songId = this.dataset.id; // Keep as string
                if (!songId || songId === 'undefined') return;
                playDiscoverySong(songId);
            });
        });
    });
</script>