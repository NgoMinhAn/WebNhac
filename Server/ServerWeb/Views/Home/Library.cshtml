@model IEnumerable<ServerWeb.Models.Song>

@{
    ViewData["Title"] = "Thư viện";
    var allSongs = Model.ToList();
    var playlistSongs = allSongs.Take(4).ToList();
    var allArtists = allSongs.Select(s => s.Author).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(a => a).ToList();
}

<div class="content-area" style="min-height: calc(100vh - 100px);">    <div id="popupPlayer" class="popup-player" aria-hidden="true">
      <button type="button" id="closePopupPlayer" class="close-player" aria-label="Đóng">×</button>
      <div class="music-controller">
        <div class="duration-bar">
          <div id="popupProgress" class="progress-filled"></div>
          <div class="progress-handle"></div>
        </div>
        <div id="timeLeft" class="time-left">0:00</div>
        <div id="timeRight" class="time-right">0:00</div>
        <div class="control-buttons">
          <button class="btn" id="favoriteBtn" type="button"><i class="fas fa-heart"></i></button>
          <button class="btn" id="shuffleBtn" type="button"><i class="fas fa-random"></i></button>
          <button class="btn" id="prevBtn" type="button"><i class="fas fa-step-backward"></i></button>
          <button class="btn play-btn" id="playPauseBtn" type="button"><i class="fas fa-play"></i></button>
          <button class="btn" id="nextBtn" type="button"><i class="fas fa-step-forward"></i></button>
          <button class="btn" id="repeatBtn" type="button"><i class="fas fa-redo"></i></button>
          <div class="volume-control">
            <button class="btn" id="volumeIcon" type="button"><i class="fas fa-volume-up"></i></button>
            <input id="volumeRange" class="volume-range" type="range" min="0" max="100" value="100" aria-label="Volume" />
          </div>
        </div>
      </div>
      <div class="cover-art">
        <div class="cover-bg"></div>
        <div class="cover-icon"></div>
      </div>
      <div class="track-info">
        <div class="track-label track-label-song">Bài hát</div>
        <div id="popupSongTitle" class="song-title">Tên bài hát</div>
        <div class="track-label track-label-artist">Nghệ sĩ</div>
        <div id="popupSongAuthor" class="song-artist">Nghệ sĩ</div>
        <div class="track-label track-label-album">Album</div>
        <div id="popupSongAlbum" class="song-album">Tên album</div>
        <div class="track-label track-label-genre">Thể loại</div>
        <div id="popupSongGenre" class="song-genre">Thể loại</div>
      </div>
    </div>
    <div style="margin-bottom: 35px;">
        <h1 class="title-yellow">Thư viện nhạc của bạn</h1>
        <p class="subtitle" style="max-width: 740px;">Những bản nhạc, nghệ sĩ, album, playlist yêu thích được lưu trong thư viện của bạn.</p>
    </div>

    <section class="music-group" style="margin-bottom: 42px;">
        <div class="group-header">
            <h2 style="color: white;">Playlist của bạn</h2>
            <button id="createPlaylist" class="btn-hero" style="padding: 10px 20px; font-size: 1rem;">Tạo playlist mới</button>
        </div>

        <div id="playlistCards" class="card-grid">
            @if (!playlistSongs.Any())
            {
                <p style="color: #eee;">Chưa có playlist nào. Hãy thêm bài hát vào thư viện của bạn đềEhiển thềEềEđây.</p>
            }
            else
            {
                foreach (var song in playlistSongs)
                {
                    <div class="music-card" data-song-id="@song.Id" data-song-name="@song.Name" data-song-author="@song.Author" data-song-album="@song.Album" data-song-genre="@song.Genre" data-file-path="@Url.Content(song.FilePath)" data-cover-path="@Url.Content(song.CoverPath)" onclick="playSongFromCard(this)">
                        <div class="card-thumb" style="background-image: url('@(string.IsNullOrEmpty(song.CoverPath) ? "https://via.placeholder.com/300x180?text=No+Cover" : Url.Content(song.CoverPath))'); background-size: cover; background-position: center;"></div>
                        <div class="card-info">
                            <h3>@song.Name</h3>
                            <p>@song.Author</p>
                        </div>
                    </div>
                }
            }
        </div>
    </section>

    <section class="music-group" style="margin-bottom: 30px;">
        <div class="group-header">
            <h2 style="color: white;">Ưu thích của bạn</h2>
            <div style="display: flex; gap: 12px; align-items: center;">
                <button id="tabSongs" class="btn-hero" style="padding: 8px 16px; font-size: 0.9rem; background: #ffffff; color: #333;">Bản nhạc</button>
                <button id="tabArtists" class="btn-hero" style="padding: 8px 16px; font-size: 0.9rem; background: rgba(255,255,255,0.2); color: #fff;">Nghệ sĩ</button>
            </div>
        </div>

        <div style="margin-bottom: 18px;">
            <div class="search-box" style="background: #fff; color: #000; width: 100%; max-width: 580px;">
                <i class="fas fa-search"></i>
                <input id="librarySearch" type="text" placeholder="Tìm kiếm nội dung" style="width: 100%;" />
            </div>
        </div>

        <div id="songContainer" class="card-grid" style="display: grid;"></div>
    </section>

</div>

@section Scripts {
<script>
    const allSongs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allSongs.Select(s => new { s.Id, s.Name, s.Author, s.Album, s.Genre, FilePath = Url.Content(s.FilePath), CoverPath = Url.Content(s.CoverPath), Duration = s.Duration.ToString(@"mm\:ss") }).ToList()));
    const artists = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allArtists));

    const tabSongs = document.getElementById('tabSongs');
    const tabArtists = document.getElementById('tabArtists');
    const songContainer = document.getElementById('songContainer');
    const librarySearch = document.getElementById('librarySearch');

    const popupPlayer = document.getElementById('popupPlayer');
    const closePopupPlayer = document.getElementById('closePopupPlayer');
    const playPauseBtn = document.getElementById('playPauseBtn');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const volumeRange = document.getElementById('volumeRange');
    const volumeIcon = document.getElementById('volumeIcon');
    const durationBar = document.querySelector('.duration-bar');
    const popupProgress = document.getElementById('popupProgress');
    const progressHandle = document.querySelector('.progress-handle');
    const timeLeft = document.getElementById('timeLeft');
    const timeRight = document.getElementById('timeRight');
    const popupSongTitle = document.getElementById('popupSongTitle');
    const popupSongAuthor = document.getElementById('popupSongAuthor');
    const popupSongAlbum = document.getElementById('popupSongAlbum');
    const popupSongGenre = document.getElementById('popupSongGenre');
    const coverIcon = document.querySelector('.cover-icon');

    let currentAudio = null;
    let isPlaying = false;
    let currentSongId = null;
    let currentSongIndex = -1;
    let currentMode = 'song';
    let playlist = allSongs || [];

    function showPopupPlayer() {
      if (!popupPlayer) return;
      popupPlayer.classList.add('visible');
      popupPlayer.setAttribute('aria-hidden', 'false');
    }

    function hidePopupPlayer() {
      if (!popupPlayer) return;
      popupPlayer.classList.remove('visible');
      popupPlayer.setAttribute('aria-hidden', 'true');
    }

    function updatePlayerDisplay(name, author, coverPath, album, genre) {
      if (popupSongTitle) popupSongTitle.textContent = name || 'Tên bài hát';
      if (popupSongAuthor) popupSongAuthor.textContent = author || 'Nghệ sĩ';
      if (popupSongAlbum) popupSongAlbum.textContent = album || 'Tên album';
      if (popupSongGenre) popupSongGenre.textContent = genre || 'Thể loại';

      if (coverIcon) {
        if (coverPath) {
          coverIcon.style.backgroundImage = `url('${coverPath}')`;
          coverIcon.style.backgroundSize = 'cover';
          coverIcon.style.backgroundPosition = 'center';
        } else {
          coverIcon.style.backgroundImage = 'none';
          coverIcon.style.backgroundColor = '#29272e';
        }
      }
    }

    function updatePlayButton() {
      const icon = playPauseBtn?.querySelector('i');
      if (icon) icon.className = isPlaying ? 'fas fa-pause' : 'fas fa-play';
    }

    function stopCurrentSong() {
      if (currentAudio) {
        currentAudio.pause();
        currentAudio.currentTime = 0;
        currentAudio.src = '';
        currentAudio = null;
      }
      isPlaying = false;
      currentSongId = null;
      currentSongIndex = -1;
      updatePlayButton();
      hidePopupPlayer();
    }

    function togglePlayPause() {
      if (!currentAudio) return;
      if (isPlaying) {
        currentAudio.pause();
        isPlaying = false;
      } else {
        currentAudio.play().catch(() => {});
        isPlaying = true;
      }
      updatePlayButton();
    }

    function updateProgressBar() {
      if (!currentAudio || !popupProgress || !progressHandle || !durationBar) return;
      const progress = (currentAudio.currentTime / currentAudio.duration) * 100;
      popupProgress.style.width = `${progress}%`;
      progressHandle.style.left = `${progress}%`;

      const formatTime = seconds => {
        if (!isFinite(seconds)) return '0:00';
        const m = Math.floor(seconds / 60);
        const s = Math.floor(seconds % 60).toString().padStart(2, '0');
        return `${m}:${s}`;
      };

      if (timeLeft) timeLeft.textContent = formatTime(currentAudio.currentTime);
      if (timeRight) timeRight.textContent = formatTime(currentAudio.duration);
    }

    function seekToPosition(event) {
      if (!currentAudio || !durationBar) return;
      const rect = durationBar.getBoundingClientRect();
      const clickX = event.clientX - rect.left;
      const percentage = Math.max(0, Math.min(1, clickX / rect.width));
      currentAudio.currentTime = percentage * currentAudio.duration;
      updateProgressBar();
    }

    function playSong(song) {
      if (!song || !song.FilePath) return;

      const existingIndex = playlist.findIndex(x => x.Id === song.Id);
      currentSongIndex = existingIndex >= 0 ? existingIndex : -1;
      currentSongId = song.Id;

      if (currentAudio) {
        if (currentSongId === song.Id) {
          // If the same song is clicked while already loaded, show popup and resume if paused.
          if (!popupPlayer.classList.contains('visible')) showPopupPlayer();
          if (!isPlaying) {
            currentAudio.play().catch(() => {});
            isPlaying = true;
          } else {
            togglePlayPause();
          }
          updatePlayButton();
          return;
        }
        stopCurrentSong();
      }

      currentAudio = new Audio(song.FilePath);
      currentAudio.volume = 1.0;
      currentAudio.addEventListener('timeupdate', updateProgressBar);
      currentAudio.addEventListener('ended', () => {
        isPlaying = false;
        updatePlayButton();
        const nextIndex = (currentSongIndex + 1) % playlist.length;
        if (playlist.length) playSong(playlist[nextIndex]);
      });

      updatePlayerDisplay(song.Name, song.Author, song.CoverPath, song.Album, song.Genre);
      showPopupPlayer();

      currentAudio.play().then(() => {
        isPlaying = true;
        updatePlayButton();
      }).catch(() => {
        isPlaying = false;
        updatePlayButton();
      });
    }

    function playSongFromCard(card) {
      const song = {
        Id: card.dataset.songId,
        Name: card.dataset.songName,
        Author: card.dataset.songAuthor,
        Album: card.dataset.songAlbum || '',
        Genre: card.dataset.songGenre || '',
        FilePath: card.dataset.filePath,
        CoverPath: card.dataset.coverPath || ''
      };
      playSong(song);
    }

    function renderSongCards(list) {
      songContainer.innerHTML = '';
      if (!list.length) {
        songContainer.innerHTML = '<p style="grid-column:1/-1;color:#ccc;">Không tìm thấy kết quả.</p>';
        return;
      }
      list.forEach(song => {
        const card = document.createElement('div');
        card.className = 'music-card';
        card.dataset.songId = song.Id;
        card.dataset.songName = song.Name;
        card.dataset.songAuthor = song.Author;
        card.dataset.songAlbum = song.Album;
        card.dataset.songGenre = song.Genre;
        card.dataset.filePath = song.FilePath;
        card.dataset.coverPath = song.CoverPath;
        card.onclick = () => playSong(song);

        const cover = document.createElement('div');
        cover.className = 'card-thumb';
        cover.style.backgroundImage = `url('${song.CoverPath ? song.CoverPath : 'https://via.placeholder.com/300x180?text=no+cover'}')`;
        cover.style.backgroundSize = 'cover';
        cover.style.backgroundPosition = 'center';

        const info = document.createElement('div');
        info.className = 'card-info';
        info.innerHTML = `<h3>${song.Name}</h3><p>${song.Author}</p>`;

        card.append(cover, info);
        songContainer.append(card);
      });
    }

    function renderArtistCards(list) {
      songContainer.innerHTML = '';
      if (!list.length) {
        songContainer.innerHTML = '<p style="grid-column:1/-1;color:#ccc;">Không tìm thấy kết quả.</p>';
        return;
      }
      list.forEach(artist => {
        const card = document.createElement('div');
        card.className = 'music-card';
        card.onclick = () => {
          const byArtist = allSongs.filter(x => x.Author.toLowerCase() === artist.toLowerCase());
          renderSongCards(byArtist);
          tabSongs.classList.remove('btn-active');
          tabArtists.classList.add('btn-active');
        };

        const info = document.createElement('div');
        info.className = 'card-info';
        info.innerHTML = `<h3>${artist}</h3><p>${allSongs.filter(x=>x.Author.toLowerCase()===artist.toLowerCase()).length} bài hát</p>`;

        card.append(info);
        songContainer.append(card);
      });
    }

    function applySearch() {
      const q = librarySearch.value.trim().toLowerCase();
      if (!q) {
        if (currentMode === 'song') renderSongCards(allSongs);
        else renderArtistCards(artists);
        return;
      }

      if (currentMode === 'song') {
        const filtered = allSongs.filter(item => item.Name.toLowerCase().includes(q) || item.Author.toLowerCase().includes(q) || item.Album.toLowerCase().includes(q));
        renderSongCards(filtered);
      } else {
        const filtered = artists.filter(item => item.toLowerCase().includes(q));
        renderArtistCards(filtered);
      }
    }

    tabSongs.addEventListener('click', () => {
      currentMode = 'song';
      tabSongs.style.background = '#fff';
      tabSongs.style.color = '#333';
      tabArtists.style.background = 'rgba(255,255,255,0.2)';
      tabArtists.style.color = '#fff';
      applySearch();
    });

    tabArtists.addEventListener('click', () => {
      currentMode = 'artist';
      tabArtists.style.background = '#fff';
      tabArtists.style.color = '#333';
      tabSongs.style.background = 'rgba(255,255,255,0.2)';
      tabSongs.style.color = '#fff';
      applySearch();
    });

    librarySearch.addEventListener('input', applySearch);

    closePopupPlayer?.addEventListener('click', stopCurrentSong);
    playPauseBtn?.addEventListener('click', togglePlayPause);
    prevBtn?.addEventListener('click', () => {
      if (!playlist.length || currentSongIndex < 0) return;
      const prevIndex = currentSongIndex > 0 ? currentSongIndex - 1 : playlist.length - 1;
      playSong(playlist[prevIndex]);
    });
    nextBtn?.addEventListener('click', () => {
      if (!playlist.length || currentSongIndex < 0) return;
      const nextIndex = (currentSongIndex + 1) % playlist.length;
      playSong(playlist[nextIndex]);
    });

    volumeRange?.addEventListener('input', (e) => {
      if (!currentAudio) return;
      const vol = Math.min(1, Math.max(0, e.target.value / 100));
      currentAudio.volume = vol;
      if (volumeIcon?.querySelector('i')) {
        const icon = volumeIcon.querySelector('i');
        icon.className = vol === 0 ? 'fas fa-volume-mute' : (vol < 0.35 ? 'fas fa-volume-low' : (vol < 0.8 ? 'fas fa-volume' : 'fas fa-volume-high'));
      }
    });

    durationBar?.addEventListener('click', seekToPosition);

    renderSongCards(allSongs);
</script>
}
        tabArtists.style.background = '#fff';
        tabArtists.style.color = '#333';
        tabSongs.style.background = 'rgba(255,255,255,0.2)';
        tabSongs.style.color = '#fff';
        applySearch();
    });

    librarySearch.addEventListener('input', applySearch);

    document.getElementById('createPlaylist').addEventListener('click', () => {
        alert('Chức năng tạo playlist đang còn đang phát triển.');
    });

    renderSongCards(allSongs);
</script>
}
