@model IEnumerable<ServerWeb.Models.Song>

@{
    ViewData["Title"] = "Thư viện";
    string FormatDuration(TimeSpan duration) => duration.TotalHours >= 1 ? duration.ToString(@"h\:mm\:ss") : duration.ToString(@"mm\:ss");
    var allSongs = Model.ToList();
    var playlistSongs = allSongs.Take(4).ToList();
    var allArtists = allSongs.Select(s => s.Author).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(a => a).ToList();
    var likedSongs = ((IEnumerable<ServerWeb.Models.Song>)ViewBag.LikedSongs)?.ToList() ?? new List<ServerWeb.Models.Song>();
    var likedArtists = likedSongs.Select(s => s.Author).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(a => a).ToList();
}

<div class="content-area" style="min-height: calc(100vh - 100px);">
    <div style="margin-bottom: 35px;">
        <h1 class="title-yellow">Thư viện nhạc của bạn</h1>
        <p class="subtitle" style="max-width: 740px;">Những bản nhạc, nghệ sĩ, album, playlist yêu thích được lưu trong thư viện của bạn.</p>
    </div>

    <section class="music-group" style="margin-bottom: 42px;">
        <div class="group-header">
            <h2 style="color: white;">Playlist của bạn</h2>
            <button id="createPlaylist" class="btn-hero" style="padding: 10px 20px; font-size: 1rem;">Tạo playlist mới</button>
        </div>

        <div id="playlistCards" class="card-grid">
            @if (!playlistSongs.Any())
            {
                <p style="color: #eee;">Chưa có playlist nào. Hãy thêm bài hát vào thư viện của bạn để hiển thị ở đây.</p>
            }
            else
            {
                foreach (var song in playlistSongs)
                {
                    <div class="music-card" data-song-id="@song.Id" data-song-name="@song.Name" data-song-author="@song.Author" data-song-album="@song.Album" data-song-genre="@song.Genre" data-song-duration="@FormatDuration(song.Duration)" @if (!string.IsNullOrEmpty(song.FilePath)) { <text>data-file-path="@Url.Content(song.FilePath)"</text> } @if (!string.IsNullOrEmpty(song.CoverPath)) { <text>data-cover-path="@Url.Content(song.CoverPath)"</text> } @if (!string.IsNullOrEmpty(song.FilePath)) { <text>onclick="playSongFromCard(this)"</text> }>
                        <div class="card-thumb" style="background-image: url('@(string.IsNullOrEmpty(song.CoverPath) ? "https://via.placeholder.com/300x180?text=No+Cover" : Url.Content(song.CoverPath))'); background-size: cover; background-position: center;"></div>
                        <div class="card-info">
                            <h3>@song.Name</h3>
                            <p>@song.Author • @FormatDuration(song.Duration)</p>
                        </div>
                    </div>
                }
            }
        </div>
    </section>

    <section class="music-group" style="margin-bottom: 30px;">
        <div class="group-header">
            <h2 style="color: white;">Ưu thích của bạn</h2>
            <div style="display: flex; gap: 12px; align-items: center;">
                <button id="tabSongs" class="btn-hero" style="padding: 8px 16px; font-size: 0.9rem; background: #ffffff; color: #333;">Bản nhạc</button>
                <button id="tabArtists" class="btn-hero" style="padding: 8px 16px; font-size: 0.9rem; background: rgba(255,255,255,0.2); color: #fff;">Nghệ sĩ</button>
            </div>
        </div>

        <div style="margin-bottom: 18px;">
            <div class="search-box" style="background: #fff; color: #000; width: 100%; max-width: 580px;">
                <i class="fas fa-search"></i>
                <input id="librarySearch" type="text" placeholder="Tìm kiếm nội dung" style="width: 100%;" />
            </div>
        </div>

        <div id="songContainer" class="card-grid" style="display: grid;"></div>
    </section>

</div>

@section Scripts {
<script>
    window.currentSongId = null;
    window.likedSongs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(likedSongs.Select(s => new { s.Id, s.Name, s.Author, s.Album, s.Genre, FilePath = !string.IsNullOrEmpty(s.FilePath) ? Url.Content(s.FilePath) : null, CoverPath = !string.IsNullOrEmpty(s.CoverPath) ? Url.Content(s.CoverPath) : null, Duration = s.Duration.TotalHours >= 1 ? s.Duration.ToString(@"h\:mm\:ss") : s.Duration.ToString(@"mm\:ss") }).ToList()));

    const allSongs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allSongs.Select(s => new { s.Id, s.Name, s.Author, s.Album, s.Genre, FilePath = !string.IsNullOrEmpty(s.FilePath) ? Url.Content(s.FilePath) : null, CoverPath = !string.IsNullOrEmpty(s.CoverPath) ? Url.Content(s.CoverPath) : null, Duration = s.Duration.TotalHours >= 1 ? s.Duration.ToString(@"h\:mm\:ss") : s.Duration.ToString(@"mm\:ss") }).ToList()));
    let likedArtists = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(likedArtists));

    let currentMode = 'song';

    function updateFavoriteIcon(isLiked) {
        const favoriteBtn = document.getElementById('favoriteBtn');
        const icon = favoriteBtn?.querySelector('i');
        if (icon) icon.className = isLiked ? 'fas fa-heart' : 'far fa-heart';
    }

    function refreshLikedArtists() {
        likedArtists = Array.from(new Set(window.likedSongs.map(s => s.Author)))
            .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: 'base' }));
    }

    window.addEventListener('songLikeToggled', event => {
        const detail = event?.detail;
        if (!detail) return;
        const songId = String(detail.songId); // Keep as string
        const liked = Boolean(detail.liked);
        if (liked) {
            const song = allSongs.find(s => String(s.Id) === songId); // Keep as string
            if (song && !window.likedSongs.some(s => String(s.Id) === songId)) { // Keep as string
                window.likedSongs.push(song);
            }
        } else {
            window.likedSongs = window.likedSongs.filter(s => String(s.Id) !== songId); // Keep as string
        }
        refreshLikedArtists();
        if (currentMode === 'song') {
            renderSongCards(window.likedSongs);
        } else {
            renderArtistCards(likedArtists);
        }
    });

    function playSongFromCard(card) {
        const songId = card.dataset.songId; // Keep as string
        if (!songId || songId === 'undefined') return;
        openPlayer(songId);
    }

    function renderSongCards(list) {
        const songContainer = document.getElementById('songContainer');
        if (!songContainer) return;
        songContainer.innerHTML = '';
        if (!list?.length) {
            songContainer.innerHTML = '<p style="grid-column:1/-1;color:#ccc;">Không tìm thấy kết quả.</p>';
            return;
        }
        list.forEach(song => {
            if (!song.FilePath) return;
            const card = document.createElement('div');
            card.className = 'music-card';
            card.dataset.songId = song.Id;
            card.dataset.songName = song.Name;
            card.dataset.songAuthor = song.Author;
            card.dataset.songAlbum = song.Album;
            card.dataset.songGenre = song.Genre;
            card.dataset.filePath = song.FilePath;
            card.dataset.coverPath = song.CoverPath || '';
            card.onclick = () => playSongFromCard(card);

            const cover = document.createElement('div');
            cover.className = 'card-thumb';
            cover.style.backgroundImage = `url('${song.CoverPath || 'https://via.placeholder.com/300x180?text=no+cover'}')`;
            cover.style.backgroundSize = 'cover';
            cover.style.backgroundPosition = 'center';
            card.dataset.songDuration = song.Duration || '';

            const info = document.createElement('div');
            info.className = 'card-info';
            info.innerHTML = `<h3>${song.Name}</h3><p>${song.Author} • ${song.Duration || '00:00'}</p>`;

            card.append(cover, info);
            songContainer.append(card);
        });
    }

    function renderArtistCards(list) {
        const songContainer = document.getElementById('songContainer');
        if (!songContainer) return;
        songContainer.innerHTML = '';
        if (!list?.length) {
            songContainer.innerHTML = '<p style="grid-column:1/-1;color:#ccc;">Không tìm thấy kết quả.</p>';
            return;
        }
        list.forEach(artist => {
            const card = document.createElement('div');
            card.className = 'music-card';
            card.onclick = () => {
                const byArtist = window.likedSongs.filter(x => x.Author.toLowerCase() === artist.toLowerCase());
                renderSongCards(byArtist);
                currentMode = 'song';
                document.getElementById('tabSongs')?.classList.add('btn-active');
                document.getElementById('tabArtists')?.classList.remove('btn-active');
            };
            const info = document.createElement('div');
            info.className = 'card-info';
            info.innerHTML = `<h3>${artist}</h3><p>${window.likedSongs.filter(x => x.Author.toLowerCase() === artist.toLowerCase()).length} bài hát</p>`;
            card.append(info);
            songContainer.append(card);
        });
    }

    function applySearch() {
        const librarySearch = document.getElementById('librarySearch');
        if (!librarySearch) return;
        const q = librarySearch.value.trim().toLowerCase();
        if (!q) {
            if (currentMode === 'song') renderSongCards(window.likedSongs);
            else renderArtistCards(likedArtists);
            return;
        }
        if (currentMode === 'song') {
            const filtered = window.likedSongs.filter(item => item.Name.toLowerCase().includes(q) || item.Author.toLowerCase().includes(q) || item.Album.toLowerCase().includes(q));
            renderSongCards(filtered);
        } else {
            const filtered = likedArtists.filter(item => item.toLowerCase().includes(q));
            renderArtistCards(filtered);
        }
    }

    function initLibraryPage() {
        const tabSongs = document.getElementById('tabSongs');
        const tabArtists = document.getElementById('tabArtists');
        const librarySearch = document.getElementById('librarySearch');
        const createPlaylistButton = document.getElementById('createPlaylist');
        const favoriteBtn = document.getElementById('favoriteBtn');

        if (tabSongs) {
            tabSongs.addEventListener('click', () => {
                currentMode = 'song';
                tabSongs.style.background = '#fff';
                tabSongs.style.color = '#333';
                tabArtists.style.background = 'rgba(255,255,255,0.2)';
                tabArtists.style.color = '#fff';
                renderSongCards(window.likedSongs);
            });
        }

        if (tabArtists) {
            tabArtists.addEventListener('click', () => {
                currentMode = 'artist';
                tabArtists.style.background = '#fff';
                tabArtists.style.color = '#333';
                tabSongs.style.background = 'rgba(255,255,255,0.2)';
                tabSongs.style.color = '#fff';
                renderArtistCards(likedArtists);
            });
        }

        if (librarySearch) {
            librarySearch.addEventListener('input', applySearch);
        }

        if (createPlaylistButton) {
            createPlaylistButton.addEventListener('click', () => {
                alert('Chức năng tạo playlist đang còn đang phát triển.');
            });
        }


        renderSongCards(window.likedSongs);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLibraryPage);
    } else {
        initLibraryPage();
    }
</script>
}
