@model IEnumerable<ServerWeb.Models.Song>

@{
  ViewData["Title"] = "Trang chủ";
  var allSongs = Model.ToList();

  string FormatDuration(TimeSpan duration) => duration.TotalHours >= 1 ? duration.ToString(@"h\:mm\:ss") : duration.ToString(@"mm\:ss");

  var firstSectionSongs = allSongs.Take(4).ToList();
  var secondSectionSongs = allSongs.Skip(4).Take(4).ToList();
}

@section Styles {
  <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
}

<div class="container">
  <section class="hero">
    <div class="hero-left">
      <div class="main-player-card">
        <div class="video-display"></div>
        <div class="player-controls">
          <div class="progress-bar"></div>
          <div class="control-buttons">
            <i class="fas fa-random"></i>
            <i class="fas fa-step-backward"></i>
            <div class="play-circle"><i class="fas fa-play"></i></div>
            <i class="fas fa-step-forward"></i>
            <i class="fas fa-redo"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <h1 class="title-yellow">Hãy cảm nhận âm nhạc</h1>
      <h1 class="title-white">theo cách riêng của bạn.</h1>
      <p class="subtitle">Tự tạo playlist theo sở thích của bạn, tận hưởng trọn vẹn âm nhạc trong không gian đầy cảm
        hứng</p>

      <div class="action-buttons">
        <button class="btn btn-primary"><i class="fas fa-play"></i> Bắt đầu nghe</button>
        <button class="btn btn-secondary"><i class="fas fa-shuffle"></i> Phát ngẫu nhiên</button>
      </div>
    </div>
  </section>

  <section class="music-group">
    <div class="group-header">
      <h2>Đề xuất cho bạn</h2>
    </div>
    <div class="card-grid">
      @foreach (var song in firstSectionSongs)
      {
        <div class="music-card" data-song-id="@song.Id" data-song-name="@Html.Encode(song.Name)" data-song-author="@Html.Encode(song.Author)" data-song-album="@Html.Encode(song.Album)" data-song-genre="@Html.Encode(song.Genre)" data-song-duration="@FormatDuration(song.Duration)" data-file-path="@Url.Content(song.FilePath)" data-cover-path="@Url.Content(song.CoverPath)" onclick="playSongFromCard(this)">
          @if (!string.IsNullOrEmpty(song.CoverPath))
          {
            <div class="card-thumb" style="background-image: url('@song.CoverPath'); background-size: cover; background-position: center;">
              <span>@FormatDuration(song.Duration)</span>
            </div>
          }
          else
          {
            <div class="card-thumb">
              <span>@FormatDuration(song.Duration)</span>
            </div>
          }
          <div class="card-info">
            <h3>@song.Name</h3>
            <p>@song.Author</p>
          </div>
        </div>
      }
    </div>
  </section>

  <section class="music-group">
    <div class="group-header">
      <h2>Nghệ sĩ nổi bật</h2>
      <a href="#" class="view-all">Hiển thị tất cả</a>
    </div>
    <div class="card-grid">
      @foreach (var song in secondSectionSongs)
      {
        <div class="music-card" data-song-id="@song.Id" data-song-name="@Html.Encode(song.Name)" data-song-author="@Html.Encode(song.Author)" data-song-album="@Html.Encode(song.Album)" data-song-genre="@Html.Encode(song.Genre)" data-song-duration="@FormatDuration(song.Duration)" data-file-path="@Url.Content(song.FilePath)" data-cover-path="@Url.Content(song.CoverPath)" onclick="playSongFromCard(this)">
          @if (!string.IsNullOrEmpty(song.CoverPath))
          {
            <div class="card-thumb" style="background-image: url('@song.CoverPath'); background-size: cover; background-position: center;">
              <span>@FormatDuration(song.Duration)</span>
            </div>
          }
          else
          {
            <div class="card-thumb">
              <span>@FormatDuration(song.Duration)</span>
            </div>
          }
          <div class="card-info">
            <h3>@song.Name</h3>
            <p>@song.Author</p>
          </div>
        </div>
      }
      @if (secondSectionSongs.Count == 0)
      {
        <p style="grid-column: 1 / -1; text-align: center; color: #999;">Chưa có bài hát nào trong phần này. Tổng số bài hát gốc: @Model.Count()</p>
      }
    </div>
  </section>
</div>

@section Scripts {
  <script>
    window.pagePlaylist = @Html.Raw(Json.Serialize(Model.Select(s => new {
        Id = s.Id,
        Name = s.Name,
        Author = s.Author,
        Album = s.Album,
        Genre = s.Genre,
        Duration = FormatDuration(s.Duration),
        FilePath = Url.Content(s.FilePath),
        CoverPath = Url.Content(s.CoverPath)
    }).ToList()));
  </script>
}