@model IEnumerable<ServerWeb.Models.Song>

@{
  ViewData["Title"] = "Trang chủ";
  var allSongs = Model.ToList();

  var firstSectionSongs = allSongs.Take(4).ToList();
  var secondSectionSongs = allSongs.Skip(4).Take(4).ToList();
}

@section Styles {
  <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
}

<div class="container">
  <div id="popupPlayer" class="popup-player" aria-hidden="true">
    <button type="button" id="closePopupPlayer" class="close-player" aria-label="Đóng">×</button>
    <div class="music-controller">
      <div class="duration-bar">
        <div id="popupProgress" class="progress-filled"></div>
        <div class="progress-handle"></div>
      </div>
      <div id="timeLeft" class="time-left">0:00</div>
      <div id="timeRight" class="time-right">0:00</div>
      <div class="control-buttons">
        <button class="btn" id="favoriteBtn" type="button"><i class="fas fa-heart"></i></button>
        <button class="btn" id="shuffleBtn" type="button"><i class="fas fa-random"></i></button>
        <button class="btn" id="prevBtn" type="button"><i class="fas fa-step-backward"></i></button>
        <button class="btn play-btn" id="playPauseBtn" type="button"><i class="fas fa-play"></i></button>
        <button class="btn" id="nextBtn" type="button"><i class="fas fa-step-forward"></i></button>
        <button class="btn" id="repeatBtn" type="button"><i class="fas fa-redo"></i></button>
        <div class="volume-control">
          <button class="btn" id="volumeIcon" type="button"><i class="fas fa-volume-up"></i></button>
          <input id="volumeRange" class="volume-range" type="range" min="0" max="100" value="100" aria-label="Volume" />
        </div>
      </div>
    </div>
    <div class="cover-art">
      <div class="cover-bg"></div>
      <div class="cover-icon"></div>
    </div>
    <div class="track-info">
      <div class="track-label track-label-song">Bài hát</div>
      <div id="popupSongTitle" class="song-title">Tên bài hát</div>
      <div class="track-label track-label-artist">Nghệ sĩ</div>
      <div id="popupSongAuthor" class="song-artist">Nghệ sĩ</div>
      <div class="track-label track-label-album">Album</div>
      <div id="popupSongAlbum" class="song-album">Tên album</div>
      <div class="track-label track-label-genre">Thể loại</div>
      <div id="popupSongGenre" class="song-genre">Thể loại</div>
    </div>
  </div>

  <section class="hero">
    <div class="hero-left">
      <div class="main-player-card">
        <div class="video-display"></div>
        <div class="player-controls">
          <div class="progress-bar"></div>
          <div class="control-buttons">
            <i class="fas fa-random"></i>
            <i class="fas fa-step-backward"></i>
            <div class="play-circle"><i class="fas fa-play"></i></div>
            <i class="fas fa-step-forward"></i>
            <i class="fas fa-redo"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <h1 class="title-yellow">Hãy cảm nhận âm nhạc</h1>
      <h1 class="title-white">theo cách riêng của bạn.</h1>
      <p class="subtitle">Tự tạo playlist theo sở thích của bạn, tận hưởng trọn vẹn âm nhạc trong không gian đầy cảm
        hứng</p>

      <div class="action-buttons">
        <button class="btn btn-primary"><i class="fas fa-play"></i> Bắt đầu nghe</button>
        <button class="btn btn-secondary"><i class="fas fa-shuffle"></i> Phát ngẫu nhiên</button>
      </div>
    </div>
  </section>

  <section class="music-group">
    <div class="group-header">
      <h2>Đề xuất cho bạn</h2>
    </div>
    <div class="card-grid">
      @foreach (var song in firstSectionSongs)
      {
        <div class="music-card" data-song-id="@song.Id" data-song-name="@Html.Encode(@Json.Serialize(song.Name))" data-song-author="@Html.Encode(@Json.Serialize(song.Author))" data-song-album="@Html.Encode(@Json.Serialize(song.Album))" data-song-genre="@Html.Encode(@Json.Serialize(song.Genre))" data-file-path="@Url.Content(song.FilePath)" data-cover-path="@Url.Content(song.CoverPath)" onclick="playSongFromCard(this)">
          @if (!string.IsNullOrEmpty(song.CoverPath))
          {
            <div class="card-thumb" style="background-image: url('@song.CoverPath'); background-size: cover; background-position: center;">
              <span>@song.Duration.ToString(@"mm\:ss")</span>
            </div>
          }
          else
          {
            <div class="card-thumb">
              <span>@song.Duration.ToString(@"mm\:ss")</span>
            </div>
          }
          <div class="card-info">
            <h3>@song.Name</h3>
            <p>@song.Author</p>
          </div>
        </div>
      }
    </div>
  </section>

  <section class="music-group">
    <div class="group-header">
      <h2>Nghệ sĩ nổi bật</h2>
      <a href="#" class="view-all">Hiển thị tất cả</a>
    </div>
    <div class="card-grid">
      @foreach (var song in secondSectionSongs)
      {
        <div class="music-card" data-song-id="@song.Id" data-song-name="@Html.Encode(@Json.Serialize(song.Name))" data-song-author="@Html.Encode(@Json.Serialize(song.Author))" data-song-album="@Html.Encode(@Json.Serialize(song.Album))" data-song-genre="@Html.Encode(@Json.Serialize(song.Genre))" data-file-path="@Url.Content(song.FilePath)" data-cover-path="@Url.Content(song.CoverPath)" onclick="playSongFromCard(this)">
          @if (!string.IsNullOrEmpty(song.CoverPath))
          {
            <div class="card-thumb" style="background-image: url('@song.CoverPath'); background-size: cover; background-position: center;">
              <span>@song.Duration.ToString(@"mm\:ss")</span>
            </div>
          }
          else
          {
            <div class="card-thumb">
              <span>@song.Duration.ToString(@"mm\:ss")</span>
            </div>
          }
          <div class="card-info">
            <h3>@song.Name</h3>
            <p>@song.Author</p>
          </div>
        </div>
      }
      @if (secondSectionSongs.Count == 0)
      {
        <p style="grid-column: 1 / -1; text-align: center; color: #999;">Chưa có bài hát nào trong phần này. Tổng số bài hát gốc: @Model.Count()</p>
      }
    </div>
  </section>
</div>

@section Scripts {
  <script>
    let currentAudio = null;
    let isPlaying = false;
    let currentSongId = null;
    let currentSongIndex = -1;
    let playlist = @Html.Raw(Json.Serialize(Model.Select(s => new {
        Id = s.Id,
        Name = s.Name,
        Author = s.Author,
        FilePath = Url.Content(s.FilePath),
        CoverPath = Url.Content(s.CoverPath)
    }).ToList()));

    function decodeHtmlEntities(str) {
      const textarea = document.createElement('textarea');
      textarea.innerHTML = str;
      return textarea.value;
    }

    function playSongFromCard(cardElement) {
      const songId = cardElement.getAttribute('data-song-id');
      const name = JSON.parse(decodeHtmlEntities(cardElement.getAttribute('data-song-name')));
      const author = JSON.parse(decodeHtmlEntities(cardElement.getAttribute('data-song-author')));
      const album = JSON.parse(decodeHtmlEntities(cardElement.getAttribute('data-song-album')));
      const genre = JSON.parse(decodeHtmlEntities(cardElement.getAttribute('data-song-genre')));
      const filePath = cardElement.getAttribute('data-file-path');
      const coverPath = cardElement.getAttribute('data-cover-path');

      console.log('Clicked song:', songId, name);
      playSong(songId, name, author, filePath, coverPath, album, genre);
    }

    function showPopupPlayer() {
      const card = document.getElementById('popupPlayer');
      if (card) {
        card.classList.add('visible');
        card.setAttribute('aria-hidden', 'false');
      }
    }

    function hidePopupPlayer() {
      const card = document.getElementById('popupPlayer');
      if (card) {
        card.classList.remove('visible');
        card.setAttribute('aria-hidden', 'true');
      }
    }

    function playSong(songId, name, author, filePath, coverPath, album, genre) {
      console.log('Attempting to play song:', { songId, name, author, filePath, coverPath, album, genre });

      // Find the song index in playlist
      const songIndex = playlist.findIndex(song => song.Id === songId);
      if (songIndex !== -1) {
        currentSongIndex = songIndex;
      }

      // If clicking the same song, toggle play/pause
      if (currentSongId === songId) {
        togglePlayPause();
        return;
      }

      // Stop and cleanup current song
      stopCurrentSong();

      // Create new audio element
      currentAudio = new Audio();
      const normalizedPath = encodeURI(filePath.trim());
      currentAudio.src = normalizedPath;
      currentSongId = songId;

      // Set initial volume from slider
      const volumeRange = document.getElementById('volumeRange');
      if (volumeRange) {
        currentAudio.volume = Math.min(1, Math.max(0, Number(volumeRange.value) / 100));
      }

      // Update player display
      updatePlayerDisplay(name, author, coverPath, album, genre);
      showPopupPlayer();

          // Set up event listeners
          currentAudio.addEventListener('loadedmetadata', function() {
            console.log('Audio metadata loaded, duration:', currentAudio.duration);
            updateProgressBar();
          });

          currentAudio.addEventListener('timeupdate', function() {
            updateProgressBar();
          });

          currentAudio.addEventListener('ended', function() {
            console.log('Song ended');
            isPlaying = false;
            updatePlayButton();
            // Auto-play next song
            playNextSong();
          });

          currentAudio.addEventListener('error', function(e) {
            // Audio loading error - but song may still play, so don't log or alert
            stopCurrentSong();
          });

          currentAudio.addEventListener('canplay', function() {
            console.log('Audio can play, ready to start');
          });

          // Start playing immediately
          currentAudio.play().then(() => {
            console.log('Audio started playing');
            isPlaying = true;
            updatePlayButton();
          }).catch(error => {
            if (error.name !== 'AbortError') {
              console.error('Error playing audio:', error);
              // Don't alert for now
            }
          });
    }

    function stopCurrentSong() {
      if (currentAudio) {
        currentAudio.pause();
        currentAudio.currentTime = 0;
        currentAudio.src = '';
        currentAudio = null;
      }
      isPlaying = false;
      currentSongId = null;
      currentSongIndex = -1;
      updatePlayButton();
      hidePopupPlayer();
    }

    function togglePlayPause() {
      if (!currentAudio) {
        console.log('No current audio to toggle');
        return;
      }

      if (isPlaying) {
        currentAudio.pause();
        isPlaying = false;
        updatePlayButton();
      } else {
        currentAudio.play().then(() => {
          isPlaying = true;
          updatePlayButton();
        }).catch(error => {
          console.error('Error resuming playback:', error);
        });
      }
    }

    function updatePlayerDisplay(name, author, coverPath, album, genre) {
      const songTitleEl = document.getElementById('popupSongTitle');
      const songAuthorEl = document.getElementById('popupSongAuthor');
      const songAlbumEl = document.getElementById('popupSongAlbum');
      const songGenreEl = document.getElementById('popupSongGenre');
      const coverIcon = document.querySelector('.cover-icon');
      const oldVideoDisplay = document.querySelector('.main-player-card .video-display');
      const oldSongTitle = document.querySelector('.hero-right .title-yellow');
      const oldSongArtist = document.querySelector('.hero-right .subtitle');

      if (songTitleEl) songTitleEl.textContent = name || 'Tên bài hát';
      if (songAuthorEl) songAuthorEl.textContent = author || 'Nghệ sĩ';
      if (songAlbumEl) songAlbumEl.textContent = album || 'Tên album';
      if (songGenreEl) songGenreEl.textContent = genre || 'Thể loại';

      if (coverPath && coverIcon) {
        coverIcon.style.backgroundImage = `url('${coverPath}')`;
        coverIcon.style.backgroundSize = 'cover';
        coverIcon.style.backgroundPosition = 'center';
      } else if (coverIcon) {
        coverIcon.style.backgroundImage = 'none';
        coverIcon.style.backgroundColor = '#29272e';
      }

      if (oldVideoDisplay) {
        if (coverPath) {
          oldVideoDisplay.style.backgroundImage = `url('${coverPath}')`;
          oldVideoDisplay.style.backgroundSize = 'cover';
          oldVideoDisplay.style.backgroundPosition = 'center';
        } else {
          oldVideoDisplay.style.backgroundImage = 'none';
          oldVideoDisplay.style.backgroundColor = '#fff';
        }
      }
    }

    function updatePlayButton() {
      const popupPlayButton = document.querySelector('#playPauseBtn i');
      const oldPlayButton = document.querySelector('.play-circle i');
      if (popupPlayButton) popupPlayButton.className = isPlaying ? 'fas fa-pause' : 'fas fa-play';
      if (oldPlayButton) oldPlayButton.className = isPlaying ? 'fas fa-pause' : 'fas fa-play';
    }

    function updateProgressBar() {
      if (!currentAudio) return;

      const progressBar = document.getElementById('popupProgress');
      const progressHandle = document.querySelector('.progress-handle');
      const timeLeft = document.getElementById('timeLeft');
      const timeRight = document.getElementById('timeRight');

      const progress = (currentAudio.currentTime / currentAudio.duration) * 100;
      if (progressBar) progressBar.style.width = progress + '%';
      if (progressHandle) progressHandle.style.left = progress + '%';

      const formatTime = seconds => {
        if (!isFinite(seconds)) return '0:00';
        const m = Math.floor(seconds / 60);
        const s = Math.floor(seconds % 60).toString().padStart(2, '0');
        return `${m}:${s}`;
      };

      if (timeLeft) timeLeft.textContent = formatTime(currentAudio.currentTime);
      if (timeRight) timeRight.textContent = formatTime(currentAudio.duration);
    }

    function seekToPosition(event) {
      if (!currentAudio || !currentAudio.duration) return;

      const durationBar = document.querySelector('.duration-bar');
      const rect = durationBar.getBoundingClientRect();
      const clickX = event.clientX - rect.left;
      const percentage = Math.max(0, Math.min(1, clickX / rect.width));

      currentAudio.currentTime = percentage * currentAudio.duration;
      updateProgressBar();
    }

    function playNextSong() {
      if (playlist.length === 0) return;

      const nextIndex = (currentSongIndex + 1) % playlist.length;
      const nextSong = playlist[nextIndex];

      playSong(nextSong.Id, nextSong.Name, nextSong.Author, nextSong.FilePath, nextSong.CoverPath, nextSong.Album, nextSong.Genre);
    }

    function playPreviousSong() {
      if (playlist.length === 0) return;

      // If current song has been playing for more than 3 seconds, restart it
      if (currentAudio && currentAudio.currentTime > 3) {
        currentAudio.currentTime = 0;
        return;
      }

      // Otherwise, go to previous song
      const prevIndex = currentSongIndex > 0 ? currentSongIndex - 1 : playlist.length - 1;
      const prevSong = playlist[prevIndex];

      playSong(prevSong.Id, prevSong.Name, prevSong.Author, prevSong.FilePath, prevSong.CoverPath, prevSong.Album, prevSong.Genre);
    }

    // Set up player controls
    document.addEventListener('DOMContentLoaded', function() {
      const playButton = document.getElementById('playPauseBtn');
      const prevButton = document.getElementById('prevBtn');
      const nextButton = document.getElementById('nextBtn');
      const closeButton = document.getElementById('closePopupPlayer');

      if (playButton) {
        playButton.addEventListener('click', togglePlayPause);
      }

      if (prevButton) {
        prevButton.addEventListener('click', playPreviousSong);
      }

      if (nextButton) {
        nextButton.addEventListener('click', playNextSong);
      }

      const volumeRange = document.getElementById('volumeRange');
      const volumeIcon = document.getElementById('volumeIcon');
      const durationBar = document.querySelector('.duration-bar');

      function setVolume(value) {
        const normalized = Math.min(1, Math.max(0, value / 100));
        if (currentAudio) currentAudio.volume = normalized;
        if (volumeIcon) {
          const icon = volumeIcon.querySelector('i');
          if (!icon) return;
          if (normalized === 0) {
            icon.className = 'fas fa-volume-mute';
          } else if (normalized < 0.35) {
            icon.className = 'fas fa-volume-low';
          } else if (normalized < 0.8) {
            icon.className = 'fas fa-volume';
          } else {
            icon.className = 'fas fa-volume-high';
          }
        }
      }

      if (volumeRange) {
        volumeRange.value = 100;
        volumeRange.addEventListener('input', (e) => {
          setVolume(parseInt(e.target.value, 10));
        });
        volumeRange.addEventListener('change', (e) => {
          setVolume(parseInt(e.target.value, 10));
        });
      }

      if (volumeIcon) {
        volumeIcon.addEventListener('click', () => {
          if (!volumeRange) return;
          if (volumeRange.value === '0') {
            volumeRange.value = 70;
          } else {
            volumeRange.value = '0';
          }
          setVolume(parseInt(volumeRange.value, 10));
        });
      }

      if (closeButton) {
        closeButton.addEventListener('click', () => {
          stopCurrentSong();
        });
      }

      if (durationBar) {
        durationBar.addEventListener('click', seekToPosition);
        durationBar.addEventListener('mousedown', (e) => {
          if (e.button !== 0) return; // Only left mouse button

          const handleMouseMove = (moveEvent) => {
            const rect = durationBar.getBoundingClientRect();
            const clickX = moveEvent.clientX - rect.left;
            const percentage = Math.max(0, Math.min(1, clickX / rect.width));

            // Update progress bar and handle position in real-time during drag
            const progressBar = document.getElementById('popupProgress');
            const progressHandle = document.querySelector('.progress-handle');
            if (progressBar) progressBar.style.width = (percentage * 100) + '%';
            if (progressHandle) progressHandle.style.left = (percentage * 100) + '%';

            // Update time display
            if (currentAudio && currentAudio.duration) {
              const timeLeft = document.getElementById('timeLeft');
              const formatTime = seconds => {
                if (!isFinite(seconds)) return '0:00';
                const m = Math.floor(seconds / 60);
                const s = Math.floor(seconds % 60).toString().padStart(2, '0');
                return `${m}:${s}`;
              };
              if (timeLeft) timeLeft.textContent = formatTime(percentage * currentAudio.duration);
            }
          };

          const handleMouseUp = () => {
            document.removeEventListener('mousemove', handleMouseMove);
            document.removeEventListener('mouseup', handleMouseUp);
            // Set the actual audio position on mouse up
            seekToPosition(e);
          };

          document.addEventListener('mousemove', handleMouseMove);
          document.addEventListener('mouseup', handleMouseUp);
        });
      }

      // Initialize volume to 100% before any play
      setVolume(100);
    });
  </script>
}