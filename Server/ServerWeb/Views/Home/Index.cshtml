@{
  ViewData["Title"] = "Trang chủ";
}

@section Styles {
  <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
}

<div class="container">
  <section class="hero">
    <div class="hero-left">
      <div class="main-player-card">
        <div class="video-display"></div>
        <div class="player-controls">
          <div class="progress-bar"></div>
          <div class="control-buttons">
            <i class="fas fa-random"></i>
            <i class="fas fa-step-backward"></i>
            <div class="play-circle"><i class="fas fa-play"></i></div>
            <i class="fas fa-step-forward"></i>
            <i class="fas fa-redo"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <h1 class="title-yellow">Hãy cảm nhận âm nhạc</h1>
      <h1 class="title-white">theo cách riêng của bạn.</h1>
      <p class="subtitle">Tự tạo playlist theo sở thích của bạn, tận hưởng trọn vẹn âm nhạc trong không gian đầy cảm
        hứng</p>

      <div class="action-buttons">
        <button class="btn btn-primary"><i class="fas fa-play"></i> Bắt đầu nghe</button>
        <button class="btn btn-secondary"><i class="fas fa-shuffle"></i> Phát ngẫu nhiên</button>
      </div>
    </div>
  </section>

  <section class="music-group">
    <div class="group-header">
      <h2>Đề xuất cho bạn</h2>
    </div>
    <div class="card-grid">
      @for (int i = 0; i < 4; i++)
      {
        <div class="music-card">
          <div class="card-thumb"><span>Time stamp</span></div>
          <div class="card-info">
            <h3>Song Name</h3>
            <p>Song Artist</p>
          </div>
        </div>
      }
    </div>
  </section>

  <section class="music-group">
    <div class="group-header">
      <h2>Nghệ sĩ nổi bật</h2>
      <a href="#" class="view-all">Hiển thị tất cả</a>
    </div>
    <div class="card-grid">
      @for (int i = 0; i < 4; i++)
      {
        <div class="music-card">
          <div class="card-thumb"><span>Time stamp</span></div>
          <div class="card-info">
            <h3>Artist Name</h3>
            <p>Artist</p>
          </div>
        </div>
      }
    </div>
  </section>
</div>