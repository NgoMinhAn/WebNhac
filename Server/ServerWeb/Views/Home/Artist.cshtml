@model IEnumerable<ServerWeb.Models.Song>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? "Nghệ sĩ";
    var artistName = ViewBag.ArtistName as string ?? "";
    var songCount = ViewBag.ArtistSongCount as int? ?? Model.Count();
}

<div class="container">
    <div class="discovery-header">
        <div class="discovery-text">
            <h1>@artistName</h1>
            <p>@songCount bài hát có sẵn. Khám phá những ca khúc mới nhất và nghe ngay.</p>
            <a class="btn btn-secondary" href="/Home/Discovery">Quay lại Khám phá</a>
        </div>
    </div>

    <div class="row mt-4">
        @foreach (var song in Model)
        {
            <div class="col-md-3">
                <div class="card mb-4">
                    <img src="@song.CoverPath" class="card-img-top" alt="@song.Name">
                    <div class="card-body">
                        <h5 class="card-title">@song.Name</h5>
                        <p class="card-text">@song.Author</p>
                        <button class="btn btn-primary play-btn" data-id="@song.Id">Nghe ngay</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
