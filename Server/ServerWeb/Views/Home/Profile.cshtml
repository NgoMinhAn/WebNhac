@model ServerWeb.Models.User

@{
    ViewData["Title"] = "Trang cá nhân";
}

<style>
    .profile-container {
        max-width: 800px;
        margin: 50px auto;
        background: rgba(28, 31, 55, 0.9);
        border-radius: 15px;
        padding: 30px;
        color: white;
        border: 1px solid #4c5a8e;
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 25px;
        border-bottom: 1px solid #4c5a8e;
        padding-bottom: 20px;
    }

    .avatar-large {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #f6da91;
    }

    .user-stats {
        display: flex;
        gap: 20px;
        margin-top: 15px;
    }

    .stat-item {
        text-align: center;
    }

    .btn-edit-profile {
        background: #f6da91;
        color: #1a1c2d;
        border: none;
        padding: 8px 20px;
        border-radius: 20px;
        font-weight: bold;
        margin-top: 10px;
        cursor: pointer;
    }
</style>

<div class="profile-container">
    <div class="profile-header">
        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
        {
            <img src="@Model.AvatarUrl" class="avatar-large" alt="Avatar" />
        }
        else
        {
            <img src="/images/default-avatar.png" class="avatar-large" alt="Default Avatar" />
        }

        <div class="profile-info">
            <h1>@Model.Username</h1>
            <p style="color: #cdd2e6;">@Model.Email</p>
            <p><em>"@Model.Bio"</em></p>
            <button class="btn-edit-profile" onclick="location.href='/Home/EditProfile'">Chỉnh sửa hồ sơ</button>
        </div>
    </div>

    <div class="user-content" style="margin-top: 30px;">
        <h3>Bài hát đã thích</h3>
        <p style="color: #cdd2e6;">(Tính năng này đang được cập nhật...)</p>
    </div>
</div>