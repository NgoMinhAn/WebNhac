@model IEnumerable<ServerWeb.Models.Song>
@{
    ViewData["Title"] = "Admin";
}

<div data-layer="Admin" class="Admin" style="width: 100vw; height: 100vh; position: relative; background: #AAAAAA; overflow: hidden">
  <div data-layer="Content" class="Content" style="width: calc(100vw * 0.786); height: calc(100vh - calc(100vh * 0.198)); left: calc(100vw * 0.216); top: calc(100vh * 0.198); position: absolute; background: #272837; overflow: hidden">
    <div data-layer="Rectangle 32" class="Rectangle32" style="width: 228px; height: 59px; left: 30px; top: 19px; position: absolute; background: #FFA64C; border-radius: 100px"></div>
    <div data-layer="+ Thêm bài hát" class="ThMBIHT" role="button" tabindex="0" onclick="openUploadPopup()" onkeydown="if(event.key==='Enter'||event.key===' ') openUploadPopup()" style="cursor: pointer; width: 234px; height: 38px; left: 45px; top: 30px; position: absolute; color: black; font-size: 25px; font-family: Poppins; font-weight: 600; word-wrap: break-word">+ Thêm bài hát</div>
    <style>
      #uploadPopup {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(12, 17, 43, 0.72);
        z-index: 10000;
        justify-content: center;
        align-items: center;
        padding: 20px;
      }
      #uploadPopup .popup-card {
        width: min(94vw, 540px);
        max-height: calc(100vh - 60px);
        background: linear-gradient(140deg, #1a1f42 0%, #28335d 100%);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 18px;
        box-shadow: 0 24px 45px rgba(0, 0, 0, 0.36);
        color: #f0f5ff;
        padding: 18px;
        position: relative;
        font-family: 'Poppins', sans-serif;
        display: flex;
        flex-direction: column;
        gap: 10px;
        overflow-y: auto;
      }
      #uploadPopup .popup-card h3 {
        margin: 0;
        font-size: 1.45rem;
        font-weight: 700;
        color: #edf4ff;
        text-align: center;
      }
      #uploadPopup .popup-card .title-line {
        height: 1px;
        width: 100%;
        margin: 6px 0 14px;
        background: linear-gradient(90deg, rgba(255,255,255,.1), rgba(255,255,255,.4), rgba(255,255,255,.1));
      }
      #uploadPopup .popup-card .description {
        font-size: .86rem;
        color: #b6c3e6;
        text-align: center;
        margin-bottom: 6px;
      }
      #uploadPopup .popup-card .close-btn {
        position: absolute;
        right: 14px;
        top: 14px;
        width: 30px;
        height: 30px;
        border: none;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.18);
        color: #ffffff;
        font-size: 20px;
        line-height: 1;
        cursor: pointer;
      }
      #uploadPopup .popup-card .form-group {
        margin-bottom: 10px;
      }
      #uploadPopup .popup-card label {
        display: block;
        margin-bottom: 6px;
        font-size: .9rem;
        color: #c7d4f6;
      }
      #uploadPopup .popup-card input[type=text],
      #uploadPopup .popup-card input[type=file],
      #uploadPopup .popup-card select {
        width: 100%;
        min-height: 42px;
        padding: 10px 12px;
        background: #273065;
        border: 1px solid #6572b4;
        border-radius: 9px;
        color: #eef2ff;
        font-size: .95rem;
      }
      #uploadPopup .popup-card .row {
        display: flex;
        gap: 12px;
      }
      #uploadPopup .popup-card .row .col {
        flex: 1;
      }
      #uploadPopup .popup-card .file-box {
        margin-top: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        background: #2d356d;
        border: 1px dashed #8aa2dd;
        border-radius: 10px;
        padding: 10px;
        cursor: pointer;
      }
      #uploadPopup .popup-card .file-box .text {
        flex: 1;
        font-size: .9rem;
        color: #e5ecff;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      #uploadPopup .popup-card .file-box .icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: #283b93;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        color: #ffffff;
      }
      #uploadPopup .popup-card .cover-preview {
        margin-top: 10px;
        width: 100%;
        height: 92px;
        border: 1px dashed #7c8fd5;
        border-radius: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
        color: #ccd7f6;
        background: #1f294f;
        text-align: center;
        font-size: .87rem;
      }
      #uploadPopup .popup-card .duration {
        margin-top: 8px;
        font-size: .88rem;
        color: #abc2f0;
        text-align: right;
      }
      #uploadPopup .popup-card .actions {
        display: flex;
        gap: 11px;
        margin-top: 14px;
      }
      #uploadPopup .popup-card .actions button {
        flex: 1;
        min-height: 45px;
        border-radius: 10px;
        border: none;
        font-weight: 700;
        font-size: 0.96rem;
        cursor: pointer;
        transition: transform .16s ease, box-shadow .16s ease;
      }
      #uploadPopup .popup-card .actions button:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 14px rgba(0, 0, 0, .22);
      }
      #uploadPopup .popup-card .btn-cancel {
        background: #404f87;
        color: #e7ebff;
      }
      #uploadPopup .popup-card .btn-save {
        background: linear-gradient(90deg, #ffab4f 0%, #ffbb6c 100%);
        color: #1f2230;
      }
      #uploadPopup .popup-card #uploadResult {
        min-height: 22px;
        margin-bottom: 6px;
        font-weight: 700;
        text-align: center;
      }
    </style>

    <div id="uploadPopup" aria-hidden="true">
      <div class="popup-card" role="dialog" aria-labelledby="uploadTitle" aria-modal="true">
        <button type="button" class="close-btn" aria-label="Đóng" onclick="closeUploadPopup()">×</button>
        <h3 id="uploadTitle">Thêm bài hát</h3>
        <div class="title-line"></div>
        <div class="description">Vui lòng điền đầy đủ thông tin và upload file nhạc (mp3)</div>
        <div id="uploadResult"></div>

        <form id="uploadSongForm" method="post" enctype="multipart/form-data" autocomplete="off">
          <input id="editingSongId" name="id" type="hidden" value="" />
          <div class="form-group">
            <label for="name">Tên bài hát <span style="color:#ffb7b7">*</span></label>
            <input id="name" name="name" type="text" placeholder="Stay" required autocomplete="off" />
          </div>

          <div class="form-group">
            <label for="author">Nghệ sĩ <span style="color:#ffb7b7">*</span></label>
            <input id="author" name="author" type="text" placeholder="The Kid Laroi" required autocomplete="off" />
          </div>

          <div class="row">
            <div class="col form-group">
              <label for="album">Album</label>
              <input id="album" name="album" type="text" placeholder="Nhập tên album" autocomplete="off" />
            </div>
            <div class="col form-group">
              <label for="genre">Thể loại</label>
              <div style="display:flex; gap:8px; align-items:center;">
                <select id="genre" name="genre" style="flex:1;">
                  <option value="">-- Chọn thể loại --</option>
                  <option value="Pop">Pop</option>
                  <option value="EDM">EDM</option>
                  <option value="Rock">Rock</option>
                </select>
                <button type="button" class="btn-add-category" onclick="addGenre()">Thêm</button>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label for="duration">Thời lượng</label>
            <input id="duration" name="duration" type="text" placeholder="02:38" autocomplete="off" />
          </div>

          <div class="form-group">
            <label for="file">File nhạc <span style="color:#ffb7b7">*</span></label>
            <input id="file" name="file" type="file" accept="audio/*" required style="padding: 6px; background: #1e223f; color: #eef1ff;" />
            <div id="fileName" style="margin-top: 4px; font-size: 0.9rem; color: #a8b4d6;">Chọn file mp3</div>
          </div>

          <div class="form-group">
            <label for="cover">Ảnh bìa (tùy chọn)</label>
            <input id="cover" name="cover" type="file" accept="image/*" style="padding: 6px; background: #1e223f; color: #eef1ff;" />
            <div id="coverPreview" style="margin-top: 8px; width: 80px; height: 80px; border-radius: 8px; background: linear-gradient(135deg, rgba(66, 74, 149, .6), rgba(32, 37, 78, .6)); display: flex; align-items: center; justify-content: center; color: #e1e4ff; font-size: 0.8rem; text-align: center;">Không có ảnh bìa</div>
          </div>

          <div class="actions">
            <button type="button" class="btn-cancel" onclick="closeUploadPopup()">Hủy</button>
            <button id="saveButton" type="submit" class="btn-save">Lưu</button>
          </div>
        </form>
      </div>
    </div>

    <div data-layer="Management" class="Management" style="width: 1071px; height: 715px; left: 44px; top: 93px; position: absolute; overflow: hidden">
      <div data-layer="ManagementBG" class="Managementbg" style="width: 1070px; height: 719px; left: 1px; top: -4px; position: absolute; background: #4F4F4F; border-radius: 20px"></div>
      <div style="position:absolute; left: 20px; top: 20px; right: 20px; bottom: 20px; overflow:auto;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
          <div style="color:white; font-size:24px; font-weight:700;">Quản lý bài hát</div>
          <input id="searchSong" type="text" placeholder="Tìm bài hát..." style="width:260px; padding:8px 12px; border-radius:8px; border:1px solid #6b76a5; background:#23294f; color:#eff2ff;" />
        </div>
        <div style="width:100%; overflow-x:auto">
          <table style="width:100%; border-collapse:collapse; color:#f0f6ff; font-size:0.95rem;">
            <thead>
              <tr style="background:#2c335f;">
                <th style="padding:10px 12px; text-align:left;">Ảnh</th>
                <th style="padding:10px 12px; text-align:left;">Tên bài hát</th>
                <th style="padding:10px 12px; text-align:left;">Nghệ sĩ</th>
                <th style="padding:10px 12px; text-align:left;">Album</th>
                <th style="padding:10px 12px; text-align:left;">Thể loại</th>
                <th style="padding:10px 12px; text-align:left;">Thời lượng</th>
                <th style="padding:10px 12px; text-align:left;">Hành động</th>
              </tr>
            </thead>
            <tbody id="songsTableBody">
              @if (!Model.Any())
              {
                <tr><td colspan="7" style="padding:16px; color:#ced5e5; text-align:center;">Không có bài hát. Vui lòng thêm bài hát.</td></tr>
              }
              else
              {
                @foreach (var song in Model)
                {
                  <tr data-song-id="@song.Id" style="border-bottom: 1px solid rgba(255,255,255,.1);">
                    <td style="padding:10px 12px;"><img src="@(song.CoverPath ?? "/images/default-cover.png")" alt="cover" style="width:48px; height:48px; object-fit:cover; border-radius:6px;" /></td>
                    <td style="padding:10px 12px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@song.Name</td>
                    <td style="padding:10px 12px;">@song.Author</td>
                    <td style="padding:10px 12px;">@song.Album</td>
                    <td style="padding:10px 12px;">@song.Genre</td>
                    <td style="padding:10px 12px;">@song.Duration.ToString(@"mm\:ss")</td>
                    <td style="padding:10px 12px;">
                      <button onclick="startEditSong(@song.Id)" style="margin-right:8px;padding:3px 8px;border:none;border-radius:6px;background:#5b76d4;color:#fff;cursor:pointer;">Sửa</button>
                      <button onclick="deleteSong(@song.Id)" style="padding:3px 8px;border:none;border-radius:6px;background:#e74c3c;color:#fff;cursor:pointer;">Xóa</button>
                    </td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <div data-layer="Header" class="Header" style="width: 100vw; height: calc(100vh * 0.198); left: 0px; top: 0px; position: absolute; overflow: hidden">
    <div data-layer="Rectangle 28" class="Rectangle28" style="width: 100vw; height: calc(100vh * 0.198); left: 0px; top: 0px; position: absolute; background: linear-gradient(0deg, #AFA7A7 0%, #272837 100%)"></div>
    <div data-layer="Rectangle 29" class="Rectangle29" style="width: 100vw; height: calc(100vh * 0.198); left: 0px; top: 0px; position: absolute; background: linear-gradient(0deg, #AFA7A7 0%, #272837 100%)"></div>
    <div data-layer="Home Button" class="HomeButton" role="button" tabindex="0" onclick="window.location.href='/'" onkeydown="if(event.key==='Enter'||event.key===' ') window.location.href='/'" style="cursor: pointer; width: 96px; height: 96px; left: calc(100vw * 0.0125); top: calc(100vh * 0.038); position: absolute">
      <div data-layer="Ellipse 1" class="Ellipse1" style="width: 96px; height: 96px; left: 0px; top: 0px; position: absolute; background: white; border-radius: 9999px"></div>
      <div data-layer="Home" class="Home" style="width: 72px; height: 67px; left: 12px; top: 14px; position: absolute; overflow: hidden">
        <div data-svg-wrapper data-layer="Icon" class="Icon" style="left: 9px; top: 5.58px; position: absolute">
          <svg width="58" height="60" viewBox="0 0 58 60" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M37.75 57.5833V29.6667H19.75V57.5833M55.75 21.2917L28.75 1.75L1.75 21.2917V52C1.75 53.4808 2.38215 54.9009 3.50736 55.948C4.63258 56.9951 6.1587 57.5833 7.75 57.5833H49.75C51.3413 57.5833 52.8674 56.9951 53.9926 55.948C55.1179 54.9009 55.75 53.4808 55.75 52V21.2917Z" stroke="var(--Icon-Default-Default, #1E1E1E)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
    <div data-svg-wrapper data-layer="Seperator" class="Seperator" style="left: calc(100vw * 0.216); top: 8px; position: absolute">
      <svg width="1" height="calc(100vh * 0.183)" viewBox="0 0 1 calc(100vh * 0.183)" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0.5 0L0.5 calc(100vh * 0.183)" stroke="black"/>
      </svg>
    </div>
    <div data-layer="Ellipse 4" class="Ellipse4" style="width: 70px; height: 70px; left: 1317px; top: 67px; position: absolute; background: #D9D9D9; border-radius: 9999px"></div>
    <div data-svg-wrapper data-layer="User" class="User" style="left: 1332px; top: 82px; position: absolute">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M33.3333 35V31.6667C33.3333 29.8986 32.6309 28.2029 31.3807 26.9526C30.1304 25.7024 28.4347 25 26.6666 25H13.3333C11.5652 25 9.86949 25.7024 8.61925 26.9526C7.369 28.2029 6.66663 29.8986 6.66663 31.6667V35M26.6666 11.6667C26.6666 15.3486 23.6819 18.3333 20 18.3333C16.3181 18.3333 13.3333 15.3486 13.3333 11.6667C13.3333 7.98477 16.3181 5 20 5C23.6819 5 26.6666 7.98477 26.6666 11.6667Z" stroke="#278D49" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div data-layer="Quản lý nhạc" class="QuNLNhC" style="width: 256px; height: 35px; left: 432px; top: 81px; position: absolute; color: white; font-size: 30px; font-family: Poppins; font-weight: 600; word-wrap: break-word">Quản lý nhạc</div>
    <div data-svg-wrapper data-layer="Music" class="Music" style="left: 363px; top: 74px; position: absolute">
      <svg width="60" height="56" viewBox="0 0 60 56" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M22.5 42V11.6667L52.5 7V37.3333M22.5 42C22.5 45.866 19.1421 49 15 49C10.8579 49 7.5 45.866 7.5 42C7.5 38.134 10.8579 35 15 35C19.1421 35 22.5 38.134 22.5 42ZM52.5 37.3333C52.5 41.1993 49.1421 44.3333 45 44.3333C40.8579 44.3333 37.5 41.1993 37.5 37.3333C37.5 33.4673 40.8579 30.3333 45 30.3333C49.1421 30.3333 52.5 33.4673 52.5 37.3333Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>
  <script>
      var currentlyEditingId = null;
      const uploadUrl = '@Url.Action("UploadSong", "Home")';
      const editUrl = '@Url.Action("EditSong", "Home")';

      function openUploadPopup() {
        document.getElementById('uploadResult').textContent = '';
        document.getElementById('uploadSongForm').reset();
        document.getElementById('editingSongId').value = '';
        currentlyEditingId = null;
        document.getElementById('uploadTitle').textContent = 'Thêm bài hát';
        document.getElementById('saveButton').textContent = 'Lưu';
        document.getElementById('fileName').textContent = 'Chọn file mp3';
        document.getElementById('duration').value = '';
        document.getElementById('coverPreview').textContent = 'Không có ảnh bìa';
        document.getElementById('coverPreview').style.backgroundImage = 'linear-gradient(135deg, rgba(66, 74, 149, .6), rgba(32, 37, 78, .6))';
        document.getElementById('coverPreview').style.color = '#e1e4ff';
        document.getElementById('uploadPopup').style.display = 'flex';
      }

      function closeUploadPopup() {
        document.getElementById('uploadPopup').style.display = 'none';
      }

      function addGenre() {
        const genreSelect = document.getElementById('genre');
        const genre = prompt('Nhập thể loại mới:');
        if (!genre) return;

        const trimmed = genre.trim();
        if (!trimmed) {
          alert('Vui lòng nhập một thể loại hợp lệ.');
          return;
        }

        const exists = Array.from(genreSelect.options).some(opt => opt.value.toLowerCase() === trimmed.toLowerCase());
        if (exists) {
          alert('Thể loại đã tồn tại.');
          genreSelect.value = trimmed;
          return;
        }

        const option = document.createElement('option');
        option.value = trimmed;
        option.textContent = trimmed;
        genreSelect.appendChild(option);
        genreSelect.value = trimmed;
      }

      function renderSongRow(song) {
        const row = document.createElement('tr');
        row.dataset.songId = song.id;
        row.innerHTML = `
          <td style="padding:10px;">
            <img src="${song.coverPath ? song.coverPath : '/images/default-cover.png'}" alt="Cover" style="width:40px;height:40px;object-fit:cover;border-radius:6px;" />
          </td>
          <td style="padding:10px;">${song.name || ''}</td>
          <td style="padding:10px;">${song.author || ''}</td>
          <td style="padding:10px;">${song.album || ''}</td>
          <td style="padding:10px;">${song.genre || ''}</td>
          <td style="padding:10px;">${song.duration || '00:00'}</td>
          <td style="padding:10px;">
            <button type="button" onclick="startEditSong(${song.id})" style="margin-right:5px;padding:5px 8px;border:none;border-radius:6px;background:#5b76d4;color:#fff;cursor:pointer;">Sửa</button>
            <button type="button" onclick="deleteSong(${song.id})" style="padding:5px 8px;border:none;border-radius:6px;background:#e74c3c;color:#fff;cursor:pointer;">Xóa</button>
          </td>
        `;
        return row;
      }

      function appendSongToTable(song) {
        const tableBody = document.getElementById('songsTableBody');
        if (!tableBody) return;
        const emptyRow = document.getElementById('noSongsRow');
        if (emptyRow) emptyRow.remove();
        tableBody.appendChild(renderSongRow(song));
      }

      async function deleteSong(id) {
        if (!confirm('Bạn có chắc muốn xóa bài hát này?')) return;
        const response = await fetch('/Home/DeleteSong', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: id })
        });
        const data = await response.json();
        if (data.success) {
          const row = document.querySelector(`tr[data-song-id="${id}"]`);
          if (row) row.remove();
        } else {
          alert(data.message || 'Xóa thất bại');
        }
      }

      function startEditSong(id) {
        const row = document.querySelector(`tr[data-song-id="${id}"]`);
        if (!row) return;

        const cells = row.querySelectorAll('td');
        const coverImg = cells[0].querySelector('img');
        const name = cells[1].textContent.trim();
        const author = cells[2].textContent.trim();
        const album = cells[3].textContent.trim();
        const genre = cells[4].textContent.trim();
        const duration = cells[5].textContent.trim();

        document.getElementById('name').value = name;
        document.getElementById('author').value = author;
        document.getElementById('album').value = album;
        document.getElementById('genre').value = genre;
        document.getElementById('duration').value = duration;
        document.getElementById('editingSongId').value = id;
        currentlyEditingId = id;
        document.getElementById('uploadTitle').textContent = 'Chỉnh sửa bài hát';
        document.getElementById('saveButton').textContent = 'Cập nhật';

        const coverPreview = document.getElementById('coverPreview');
        if (coverImg && coverImg.src && !coverImg.src.includes('default-cover.png')) {
          coverPreview.style.backgroundImage = `url('${coverImg.src}')`;
          coverPreview.style.color = '#fff';
          coverPreview.textContent = '';
        } else {
          coverPreview.style.backgroundImage = 'linear-gradient(135deg, rgba(66, 74, 149, .6), rgba(32, 37, 78, .6))';
          coverPreview.style.color = '#e1e4ff';
          coverPreview.textContent = 'Không có ảnh bìa';
        }

        openUploadPopup();
      }

      function formatDuration(seconds) {
        const m = Math.floor(seconds / 60).toString().padStart(2, '0');
        const s = Math.floor(seconds % 60).toString().padStart(2, '0');
        return m + ':' + s;
      }

      function handleFileChange() {
        const fileInput = document.getElementById('file');
        const fileName = document.getElementById('fileName');
        const durationInput = document.getElementById('duration');
        const coverPreview = document.getElementById('coverPreview');

        if (!fileInput.files.length) {
          fileName.textContent = 'Chọn file mp3';
          durationInput.value = '';
          coverPreview.textContent = 'Không có ảnh bìa';
          coverPreview.style.backgroundImage = 'none';
          return;
        }

        const file = fileInput.files[0];
        fileName.textContent = file.name;

        const audio = document.createElement('audio');
        audio.preload = 'metadata';
        audio.src = URL.createObjectURL(file);
        audio.addEventListener('loadedmetadata', function () {
          const detectedDuration = formatDuration(audio.duration);
          fileName.textContent = file.name + ' (' + detectedDuration + ')';
          durationInput.value = detectedDuration;
          URL.revokeObjectURL(audio.src);
        });

        coverPreview.textContent = '';
        coverPreview.style.backgroundImage = 'linear-gradient(135deg, rgba(66, 74, 149, .6), rgba(32, 37, 78, .6))';
        coverPreview.style.color = '#e1e4ff';
      }

      document.addEventListener('DOMContentLoaded', function () {
        const fileInput = document.getElementById('file');
        fileInput.addEventListener('change', handleFileChange);

        const coverInput = document.getElementById('cover');
        coverInput.addEventListener('change', function() {
          const coverPreview = document.getElementById('coverPreview');
          if (this.files.length) {
            const reader = new FileReader();
            reader.onload = function(e) {
              coverPreview.style.backgroundImage = `url('${e.target.result}')`;
              coverPreview.style.color = '#fff';
              coverPreview.textContent = '';
            };
            reader.readAsDataURL(this.files[0]);
          } else {
            coverPreview.style.backgroundImage = 'linear-gradient(135deg, rgba(66, 74, 149, .6), rgba(32, 37, 78, .6))';
            coverPreview.style.color = '#e1e4ff';
            coverPreview.textContent = 'Không có ảnh bìa';
          }
        });

        const form = document.getElementById('uploadSongForm');
        form.addEventListener('submit', async function (event) {
          event.preventDefault();

          const editId = document.getElementById('editingSongId').value;

          const formData = new FormData(form);
          if (editId) formData.append('id', editId);

          // Add duration from the input
          const durationValue = document.getElementById('duration').value.trim();
          if (durationValue) {
            formData.append('duration', durationValue);
          }

          const resultEl = document.getElementById('uploadResult');
          resultEl.style.color = '#ffffff';
          resultEl.textContent = 'Đang xử lý...';

          const url = editId ? editUrl : uploadUrl;

          try {
            const response = await fetch(url, {
              method: 'POST',
              headers: {
                'X-Requested-With': 'XMLHttpRequest'
              },
              body: formData
            });

            if (!response.ok) {
              const text = await response.text();
              throw new Error(`HTTP ${response.status}: ${text}`);
            }

            const data = await response.json();
            if (data.success) {
              resultEl.style.color = '#95f39f';
              resultEl.textContent = data.message || 'Thao tác thành công.';

              const songData = data.song || {
                id: data.id,
                name: document.getElementById('name').value,
                author: document.getElementById('author').value,
                album: document.getElementById('album').value || 'Chưa có',
                genre: document.getElementById('genre').value || 'Chưa có',
                duration: document.getElementById('duration').value || '00:00',
                coverPath: ''
              };

              if (editId) {
                const existingRow = document.querySelector(`tr[data-song-id="${songData.id}"]`);
                if (existingRow) {
                  const updatedRow = renderSongRow(songData);
                  existingRow.replaceWith(updatedRow);
                }
              } else {
                appendSongToTable(songData);
              }

              setTimeout(function () {
                closeUploadPopup();
              }, 800);
            } else {
              resultEl.style.color = '#ff9494';
              resultEl.textContent = data.message || 'Xảy ra lỗi. Vui lòng thử lại.';
            }
          } catch (ex) {
            resultEl.style.color = '#ff9494';
            resultEl.textContent = 'Lỗi kết nối hoặc server.';
            console.error(ex);
          }
        });

        const searchInput = document.getElementById('searchSong');
        searchInput?.addEventListener('input', function () {
          const term = this.value.toLowerCase();
          document.querySelectorAll('#songsTableBody tr').forEach((row) => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(term) ? '' : 'none';
          });
        });

        window.addEventListener('click', function (e) {
          const popup = document.getElementById('uploadPopup');
          if (e.target === popup) closeUploadPopup();
        });
      });
    </script>

    <script>
      // chỉ dùng 1 event handler (đã được khai báo ở script phía trên)
      // để tránh trùng lặp logic và URL cố định.
    </script>
