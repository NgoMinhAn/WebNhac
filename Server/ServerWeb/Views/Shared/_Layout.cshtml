<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Music App</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        .auth-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            z-index: 10001;
            justify-content: center;
            align-items: center;
        }

        .auth-card {
            background: #282828;
            padding: 40px;
            border-radius: 12px;
            width: 400px;
            position: relative;
            color: white;
        }
    </style>
</head>

<body>
    <div class="main-wrapper">
        <aside class="side-menu">
            <div class="logo">
                <i class="fas fa-music"></i>
                <span>Music</span>
            </div>
            <ul class="nav-links">
                <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                    <a href="/"><i class="fas fa-home"></i> Trang chủ</a>
                </li>
                <li><a href="/Home/Library"><i class="fas fa-book-open"></i> Thư viện</a></li>
                <li><a href="/Home/Discovery"><i class="fas fa-compass"></i> Khám phá</a></li>
                <li><a href="/Playlist/Index"><i class="fas fa-list"></i> Danh sách phát</a></li>
            </ul>
            <button class="btn-create-playlist" onclick="location.href='/Playlist/Create'">
                <i class="fas fa-plus"></i> Tạo playlist mới
            </button>
        </aside>

        <div class="right-section">
            <nav class="top-navbar">
                <div class="nav-breadcrumb">Trang chủ</div>
                <div class="search-container">
                    <form action="/Home/Search" method="get" style="display:flex; width:100%">
                        <div class="search-box" style="flex:1">
                            <i class="fas fa-search"></i>
                            <input name="query" type="text" placeholder="Tìm kiếm nội dung" value="@(Context.Request.Query["query"].ToString())">
                        </div>
                        <input type="hidden" name="genre" value="@(Context.Request.Query["genre"].ToString())">
                    </form>
                </div>
                <div class="auth-buttons">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="user-info" style="display: flex; align-items: center; gap: 15px;">
                            <a href="/Home/Profile"
                                style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
                                <span style="color: white; font-weight: 600;">
                                    <i class="fas fa-user-circle"></i> @User.Identity.Name
                                </span>
                            </a>
                            <a href="/Auth/Logout"
                                style="color: #ff4d4d; text-decoration: none; font-size: 14px; font-weight: 700;">Đăng
                                xuất</a>
                        </div>
                    }
                    else
                    {
                        <button class="btn-signup" onclick="openAuth('register')">Đăng ký</button>
                        <button class="btn-login" onclick="openAuth('login')">Đăng nhập</button>
                    }
                </div>
            </nav>

            <main class="content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <div id="popupPlayer" class="popup-player" aria-hidden="true">
      <button type="button" id="closePopupPlayer" class="close-player" aria-label="Đóng">×</button>
      <div class="music-controller">
        <div class="duration-bar" id="popupDurationBar">
          <div id="popupProgress" class="progress-filled"></div>
          <div class="progress-handle"></div>
        </div>
        <div id="timeLeft" class="time-left">0:00</div>
        <div id="timeRight" class="time-right">0:00</div>
        <div class="control-buttons">
          <button class="btn" id="favoriteBtn" type="button"><i class="far fa-heart"></i></button>
          <button class="btn" id="shuffleBtn" type="button"><i class="fas fa-random"></i></button>
          <button class="btn" id="prevBtn" type="button"><i class="fas fa-step-backward"></i></button>
          <button class="btn play-btn" id="playPauseBtn" type="button"><i class="fas fa-play"></i></button>
          <button class="btn" id="nextBtn" type="button"><i class="fas fa-step-forward"></i></button>
          <button class="btn" id="repeatBtn" type="button"><i class="fas fa-redo"></i></button>
          <div class="volume-control">
            <button class="btn" id="volumeIcon" type="button"><i class="fas fa-volume-up"></i></button>
            <input id="volumeRange" class="volume-range" type="range" min="0" max="100" value="100" aria-label="Volume" />
          </div>
        </div>
      </div>
      <div class="cover-art">
        <div class="cover-bg"></div>
      </div>
      <div class="track-info">
        <div class="track-label track-label-song">Bài hát</div>
        <div id="popupSongTitle" class="song-title">Tên bài hát</div>
        <div class="track-label track-label-artist">Nghệ sĩ</div>
        <div id="popupSongAuthor" class="song-artist">Nghệ sĩ</div>
        <div class="track-label track-label-album">Album</div>
        <div id="popupSongAlbum" class="song-album">Tên album</div>
        <div class="track-label track-label-genre">Thể loại</div>
        <div id="popupSongGenre" class="song-genre">Thể loại</div>
      </div>
    </div>

    <audio id="main-audio"></audio>

    <div id="authModal" class="auth-overlay" onclick="closeAuth(event)">
        <div class="auth-card" onclick="event.stopPropagation()">
            <span class="close-x" onclick="closeAuth(null)">&times;</span>
            <div id="authContent"></div>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        const audio = document.getElementById('main-audio');
        const popupPlayer = document.getElementById('popupPlayer');
        const popupDurationBar = document.getElementById('popupDurationBar');
        const popupProgress = document.getElementById('popupProgress');
        const progressHandle = document.querySelector('.progress-handle');
        const timeLeft = document.getElementById('timeLeft');
        const timeRight = document.getElementById('timeRight');
        const playPauseBtn = document.getElementById('playPauseBtn');
        const closePopupPlayer = document.getElementById('closePopupPlayer');
        const volumeRange = document.getElementById('volumeRange');
        const volumeIcon = document.getElementById('volumeIcon');
        const favoriteBtn = document.getElementById('favoriteBtn');

        let isPlaying = false;
        let currentPlaylist = [];
        let currentPlaylistIds = [];
        let currentSongIndex = -1;
        let currentSongId = null;

        function decodeHtmlEntities(str) {
            const textarea = document.createElement('textarea');
            textarea.innerHTML = str || '';
            return textarea.value;
        }

        function getSongFromCard(card) {
            if (!card) return null;
            return {
                Id: card.dataset.songId || card.dataset.id, // Keep as string
                Name: decodeHtmlEntities(card.dataset.songName || card.dataset.name || ''),
                Author: decodeHtmlEntities(card.dataset.songAuthor || card.dataset.author || ''),
                Album: decodeHtmlEntities(card.dataset.songAlbum || card.dataset.album || ''),
                Genre: decodeHtmlEntities(card.dataset.songGenre || card.dataset.genre || ''),
                Duration: card.dataset.songDuration || card.dataset.duration || '',
                FilePath: card.dataset.filePath,
                CoverPath: card.dataset.coverPath || ''
            };
        }

        function getPagePlaylist() {
            if (Array.isArray(window.pagePlaylist) && window.pagePlaylist.length) {
                return window.pagePlaylist;
            }
            const cards = document.querySelectorAll('.music-card[data-song-id][data-file-path]');
            return Array.from(cards).map(getSongFromCard).filter(song => song && song.FilePath);
        }

        function showPopupPlayer() {
            console.log('showPopupPlayer called, popupPlayer element:', popupPlayer);
            if (!popupPlayer) {
                console.error('popupPlayer element not found');
                return;
            }
            console.log('Adding visible class to popupPlayer');
            popupPlayer.classList.add('visible');
            popupPlayer.setAttribute('aria-hidden', 'false');
        }

        function hidePopupPlayer() {
            if (!popupPlayer) return;
            popupPlayer.classList.remove('visible');
            popupPlayer.setAttribute('aria-hidden', 'true');
        }

        function updatePlayerDisplay(song) {
            if (!song) return;
            const titleEl = document.getElementById('popupSongTitle');
            const authorEl = document.getElementById('popupSongAuthor');
            const albumEl = document.getElementById('popupSongAlbum');
            const genreEl = document.getElementById('popupSongGenre');
            const coverBg = document.querySelector('.cover-bg');

            if (titleEl) titleEl.textContent = song.Name || 'Tên bài hát';
            if (authorEl) authorEl.textContent = song.Author || 'Nghệ sĩ';
            if (albumEl) albumEl.textContent = song.Album || 'Single';
            if (genreEl) genreEl.textContent = song.Genre || 'Âm nhạc';

            if (coverBg) {
                if (song.CoverPath) {
                    coverBg.style.backgroundImage = `url('${song.CoverPath}')`;
                    coverBg.style.backgroundSize = 'cover';
                    coverBg.style.backgroundPosition = 'center';
                } else {
                    coverBg.style.backgroundImage = 'none';
                    coverBg.style.backgroundColor = '#29272e';
                }
            }
        }

        function updateFavoriteIcon(isLiked) {
            if (!favoriteBtn) return;
            const icon = favoriteBtn.querySelector('i');
            if (icon) icon.className = isLiked ? 'fas fa-heart' : 'far fa-heart';
        }

        function toggleFavorite() {
            if (!favoriteBtn || currentSongId === null) return;
            console.log('toggleFavorite called with currentSongId:', currentSongId);
            fetch('/Home/ToggleLike', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ SongId: currentSongId }) // PascalCase to match C# model
            })
                .then(res => {
                    console.log('ToggleLike HTTP status:', res.status);
                    if (!res.ok) {
                        throw new Error(`HTTP ${res.status}: ${res.statusText}`);
                    }
                    return res.text().then(text => {
                        try {
                            return JSON.parse(text);
                        } catch (e) {
                            console.error('Failed to parse JSON response:', text);
                            throw new Error('Invalid JSON response from server');
                        }
                    });
                })
                .then(data => {
                    console.log('ToggleLike response:', data);
                    if (!data || !data.success) {
                        console.warn('Unable to toggle favorite:', data?.message);
                        return;
                    }
                    updateFavoriteIcon(data.liked);
                    window.dispatchEvent(new CustomEvent('songLikeToggled', { detail: { songId: currentSongId, liked: data.liked } }));
                })
                .catch(err => console.error('Error toggling favorite:', err));
        }

        function updatePlayButton() {
            if (!playPauseBtn) return;
            const icon = playPauseBtn.querySelector('i');
            if (icon) icon.className = isPlaying ? 'fas fa-pause' : 'fas fa-play';
        }

        function setPlaylist(playlist, songId = null) {
            if (Array.isArray(playlist) && playlist.length) {
                if (typeof playlist[0] === 'object') {
                    currentPlaylist = playlist;
                    currentPlaylistIds = playlist.map(item => String(item.Id)); // Keep as strings
                } else {
                    currentPlaylist = [];
                    currentPlaylistIds = playlist.map(id => String(id)); // Keep as strings
                }
            }
            if (songId !== null) {
                const songIdStr = String(songId); // Convert songId to string for comparison
                currentSongIndex = currentPlaylistIds.indexOf(songIdStr);
                console.log('setPlaylist - songId:', songIdStr, 'found at index:', currentSongIndex, 'playlist:', currentPlaylistIds);
            }
        }

        function fetchSongDetails(songId) {
            const url = `/Song/GetSongDetails/${songId}`;
            console.log('Fetching song details from:', url);
            return fetch(url)
                .then(res => {
                    console.log('API response status:', res.status);
                    if (!res.ok) {
                        throw new Error(`HTTP ${res.status}: ${res.statusText}`);
                    }
                    return res.json();
                })
                .then(song => {
                    console.log('Raw API response:', song);
                    const transformedSong = {
                        Id: songId, // Keep as string - MongoDB ObjectIds are strings
                        Name: song.name,
                        Author: song.author,
                        Album: song.album || 'Single',
                        Genre: song.genre || 'Âm nhạc',
                        Duration: song.duration,
                        FilePath: song.audioUrl,
                        CoverPath: song.imageUrl,
                        Liked: Boolean(song.liked)
                    };
                    console.log('Transformed song object:', transformedSong);
                    return transformedSong;
                });
        }

        function playSong(song) {
            console.log('playSong called with song:', song);
            if (!song) {
                console.error('Song object is null or undefined');
                return;
            }
            
            if (!song.FilePath) {
                console.error('Song has no FilePath:', song);
                alert('This song has no audio file associated with it.');
                return;
            }
            
            const songId = String(song.Id); // Keep as string
            console.log('Playing song - songId:', songId, 'FilePath:', song.FilePath);
            
            if (currentSongId === songId && audio.src && audio.src.includes(encodeURI(song.FilePath))) {
                console.log('Same song already loaded, toggling play');
                togglePlay();
                return;
            }

            setPlaylist(getPagePlaylist(), songId);
            currentSongIndex = currentPlaylistIds.indexOf(songId);
            currentSongId = songId;
            window.currentSongId = songId;

            const encodedPath = encodeURI(song.FilePath);
            console.log('Setting audio source to:', encodedPath);
            audio.src = encodedPath;
            
            audio.play().then(() => {
                isPlaying = true;
                updatePlayButton();
                showPopupPlayer();
                console.log('Playing audio successfully');
            }).catch(err => {
                console.error('Error playing audio:', err);
                alert('Failed to play audio: ' + err.message);
                isPlaying = false;
                updatePlayButton();
            });

            updatePlayerDisplay(song);
            updateFavoriteIcon(Boolean(song.Liked));
        }

        function playSongFromCard(card) {
            const songId = card.dataset.songId || card.dataset.id; // Keep as string
            console.log('playSongFromCard called with songId:', songId);
            if (!songId || songId === 'undefined') {
                console.error('No valid songId found in card data');
                return;
            }
            openPlayer(songId);
        }

        function openPlayer(songId, playlist = null) {
            console.log('openPlayer called with songId:', songId, 'playlist:', playlist);
            if (!songId || songId === 'undefined') {
                console.error('Invalid songId provided to openPlayer');
                return;
            }
            
            if (playlist) {
                setPlaylist(playlist, songId);
            } else {
                setPlaylist(getPagePlaylist(), songId);
            }

            console.log('Fetching song details for:', songId);
            fetchSongDetails(songId)
                .then(song => {
                    console.log('Song details fetched:', song);
                    if (!song) {
                        console.error('Song is null or undefined');
                        return;
                    }
                    playSong(song);
                })
                .catch(err => {
                    console.error('Lỗi lấy dữ liệu bài hát:', err);
                    alert('Failed to load song. Please check the console for details.');
                });
        }

        function loadSong(songId) {
            const songIdStr = String(songId);
            setPlaylist(currentPlaylistIds, songIdStr);
            currentSongIndex = currentPlaylistIds.indexOf(songIdStr);
            fetchSongDetails(songIdStr)
                .then(song => {
                    if (!song) return;
                    playSong(song);
                })
                .catch(err => console.error('Lỗi tải bài hát:', err));
        }

        function nextSong() {
            if (!currentPlaylistIds.length) return;
            currentSongIndex = (currentSongIndex + 1) % currentPlaylistIds.length;
            loadSong(currentPlaylistIds[currentSongIndex]);
        }

        function prevSong() {
            if (!currentPlaylistIds.length) return;
            currentSongIndex = (currentSongIndex - 1 + currentPlaylistIds.length) % currentPlaylistIds.length;
            loadSong(currentPlaylistIds[currentSongIndex]);
        }

        audio.ontimeupdate = () => {
            if (audio.duration && popupProgress) {
                const progress = (audio.currentTime / audio.duration) * 100;
                popupProgress.style.width = `${progress}%`;
                if (progressHandle) progressHandle.style.left = `${progress}%`;
                if (timeLeft) timeLeft.textContent = formatTime(audio.currentTime);
                if (timeRight) timeRight.textContent = formatTime(audio.duration);
            }
        };

        function seekAudio(e) {
            const bar = popupDurationBar;
            if (!bar || !audio.duration) return;
            const rect = bar.getBoundingClientRect();
            const clickX = e.clientX - rect.left;
            const percentage = Math.max(0, Math.min(1, clickX / rect.width));
            audio.currentTime = percentage * audio.duration;
        }

        function formatTime(seconds) {
            if (!isFinite(seconds)) return '0:00';
            const min = Math.floor(seconds / 60);
            const sec = Math.floor(seconds % 60);
            return min + ':' + (sec < 10 ? '0' + sec : sec);
        }

        function togglePlay() {
            if (!audio.src) return;
            if (audio.paused) {
                audio.play().catch(() => {});
                isPlaying = true;
            } else {
                audio.pause();
                isPlaying = false;
            }
            updatePlayButton();
        }

        function stopCurrentSong() {
            if (!audio) return;
            audio.pause();
            audio.currentTime = 0;
            audio.src = '';
            isPlaying = false;
            currentSongId = null;
            currentSongIndex = -1;
            currentPlaylist = [];
            currentPlaylistIds = [];
            updatePlayButton();
            hidePopupPlayer();
        }

        if (closePopupPlayer) {
            closePopupPlayer.addEventListener('click', stopCurrentSong);
        }

        if (volumeRange) {
            volumeRange.addEventListener('input', (e) => {
                if (!audio) return;
                const normalized = Math.min(1, Math.max(0, e.target.value / 100));
                audio.volume = normalized;
                if (volumeIcon?.querySelector('i')) {
                    const icon = volumeIcon.querySelector('i');
                    icon.className = normalized === 0 ? 'fas fa-volume-mute' : (normalized < 0.35 ? 'fas fa-volume-low' : (normalized < 0.8 ? 'fas fa-volume' : 'fas fa-volume-high'));
                }
            });
        }

        if (popupDurationBar) {
            popupDurationBar.addEventListener('click', seekAudio);
        }

        if (playPauseBtn) {
            playPauseBtn.addEventListener('click', togglePlay);
        }

        if (favoriteBtn) {
            favoriteBtn.addEventListener('click', toggleFavorite);
        }

        if (document.getElementById('shuffleBtn')) {
            document.getElementById('shuffleBtn').addEventListener('click', () => {
                currentPlaylistIds = currentPlaylistIds.sort(() => Math.random() - 0.5);
                currentSongIndex = currentPlaylistIds.indexOf(Number(currentSongId));
            });
        }

        function showUserPlaylists(event) {
            event.preventDefault();
            const dropdown = document.getElementById('playlistDropdown');
            const arrow = document.getElementById('playlistArrow');

            if (dropdown.style.display === 'block') {
                dropdown.style.display = 'none';
                arrow.classList.remove('open');
                return;
            }

            if (dropdown.childElementCount > 0) {
                dropdown.style.display = 'block';
                arrow.classList.add('open');
                return;
            }

            fetch('/Playlist/GetUserPlaylists')
                .then(res => {
                    if (!res.ok) throw new Error('Không thể tải playlist');
                    return res.json();
                })
                .then(playlists => {
                    dropdown.innerHTML = '';
                    if (!playlists.length) {
                        dropdown.innerHTML = '<li>Chưa có playlist nào</li>';
                    } else {
                        playlists.forEach(playlist => {
                            const li = document.createElement('li');
                            const row = document.createElement('div');
                            row.className = 'playlist-list-item';

                            const container = document.createElement('div');
                            const anchor = document.createElement('a');
                            anchor.href = `/Playlist/Details/${playlist.id}`;
                            anchor.textContent = playlist.name;
                            anchor.title = playlist.description || '';
                            anchor.style.flex = '1';
                            container.appendChild(anchor);

                            if (playlist.description) {
                                const desc = document.createElement('small');
                                desc.textContent = playlist.description;
                                container.appendChild(desc);
                            }

                            const deleteBtn = document.createElement('button');
                            deleteBtn.type = 'button';
                            deleteBtn.className = 'playlist-delete-btn';
                            deleteBtn.innerHTML = '<i class="fas fa-trash"></i>';
                            deleteBtn.onclick = function (event) {
                                event.stopPropagation();
                                event.preventDefault();
                                deletePlaylistFromSidebar(playlist.id, li);
                            };

                            row.appendChild(container);
                            row.appendChild(deleteBtn);
                            li.appendChild(row);
                            dropdown.appendChild(li);
                        });
                    }
                    dropdown.style.display = 'block';
                    arrow.classList.add('open');
                })
                .catch(err => {
                    console.error(err);
                    dropdown.innerHTML = '<li>Không tải được playlist. Hãy thử lại.</li>';
                    dropdown.style.display = 'block';
                    arrow.classList.add('open');
                });
        }

        document.addEventListener('click', function (event) {
            const dropdown = document.getElementById('playlistDropdown');
            const playItem = event.target.closest('.playlist-menu-item');

            if (!playItem && dropdown && dropdown.style.display === 'block') {
                dropdown.style.display = 'none';
                document.getElementById('playlistArrow').classList.remove('open');
            }
        });

        async function deletePlaylistFromSidebar(playlistId, listItem) {
            if (!confirm('Bạn có chắc muốn xóa playlist này?')) return;

            try {
                const response = await fetch(`/Playlist/Delete/${playlistId}`, {
                    method: 'POST'
                });

                if (!response.ok) {
                    alert('Xóa playlist thất bại. Vui lòng thử lại.');
                    return;
                }

                listItem.remove();
                const dropdown = document.getElementById('playlistDropdown');

                if (dropdown.childElementCount === 0) {
                    dropdown.innerHTML = '<li>Chưa có playlist nào</li>';
                }
            } catch (err) {
                console.error(err);
                alert('Có lỗi xảy ra khi xóa playlist.');
            }
        }

        // --- LOGIC AUTH ---
        function openAuth(type) {
            const modal = document.getElementById('authModal');
            const content = document.getElementById('authContent');
            modal.style.display = 'flex';

            if (type === 'login') {
                content.innerHTML = `
                    <div class="auth-title">Đăng nhập</div>
                    <div class="auth-subtitle">Đăng nhập để tiếp tục khám phá và lưu nhạc yêu thích.</div>
                    <form onsubmit="handleAuthSubmit(event, 'login')" action="/Auth/Login" method="post">
                        <div class="auth-field">
                            <label>Email / Username</label>
                            <input type="text" name="Email" placeholder="Nhập email hoặc tên người dùng" required>
                        </div>
                        <div class="auth-field">
                            <label>Mật khẩu</label>
                            <input type="password" name="Password" placeholder="Nhập mật khẩu" required>
                        </div>
                        <button type="submit" class="btn-continue">Đăng nhập</button>
                    </form>
                    <div class="auth-or">Hoặc</div>
                    <button type="button" class="btn-social btn-phone"><i class="fas fa-mobile-alt"></i> Đăng nhập bằng số điện thoại</button>
                    <button type="button" class="btn-social btn-fb"><i class="fab fa-facebook"></i> Đăng nhập bằng Facebook</button>
                    <div class="auth-footer">Chưa có tài khoản? <a href="#" onclick="openAuth('register'); return false;">Đăng ký ngay</a></div>
                `;
            } else {
                content.innerHTML = `
                    <div class="auth-title">Đăng ký</div>
                    <div class="auth-subtitle">Tạo tài khoản mới và bắt đầu nghe nhạc theo phong cách của bạn.</div>
                    <form onsubmit="handleAuthSubmit(event, 'register')" action="/Auth/Register" method="post">
                        <div class="auth-field">
                            <label>E-mail</label>
                            <input type="email" name="Email" placeholder="vd: name@domain.com" required>
                        </div>
                        <div class="auth-field">
                            <label>Tên đăng nhập</label>
                            <input type="text" name="Username" placeholder="Tên hiển thị của bạn" required>
                        </div>
                        <div class="auth-field">
                            <label>Mật khẩu</label>
                            <input type="password" name="Password" placeholder="Nhập mật khẩu" required>
                        </div>
                        <div class="auth-field">
                            <label>Xác nhận mật khẩu</label>
                            <input type="password" name="ConfirmPassword" placeholder="Nhập lại mật khẩu" required>
                        </div>
                        <button type="submit" class="btn-continue">Đăng ký</button>
                    </form>
                    <div class="auth-or">Hoặc</div>
                    <button type="button" class="btn-social btn-phone"><i class="fas fa-mobile-alt"></i> Đăng ký bằng số điện thoại</button>
                    <button type="button" class="btn-social btn-fb"><i class="fab fa-facebook"></i> Đăng ký bằng Facebook</button>
                    <div class="auth-footer">Bạn đã có tài khoản? <a href="#" onclick="openAuth('login'); return false;">Đăng nhập ngay</a></div>
                `;
            }
        }

        function closeAuth(e) {
            if (!e || e.target.id === 'authModal') {
                document.getElementById('authModal').style.display = 'none';
            }
        }

        function handleAuthSubmit(e, type) {
            e.preventDefault();
            const form = e.target;
            fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
                .then(async res => {
                    const text = await res.text();
                    try {
                        return JSON.parse(text);
                    } catch {
                        return { success: false, message: text || 'Có lỗi xảy ra, vui lòng thử lại.' };
                    }
                })
                .then(data => {
                    if (data.success) window.location.href = data.redirectUrl || '/';
                    else alert(data.message);
                })
                .catch(err => {
                    alert(err.message || 'Có lỗi xảy ra, vui lòng thử lại.');
                });
        }
    </script>
</body>

</html>