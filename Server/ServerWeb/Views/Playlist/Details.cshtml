@model ServerWeb.Models.Playlist

@{
    ViewData["Title"] = Model?.Name;
}

<div class="playlist-page">
    <div class="playlist-header">
        @* PHẦN ẢNH BÌA: Click để thay đổi *@
        <div class="playlist-cover" onclick="document.getElementById('fileInput').click()"
            style="cursor: pointer; position: relative;">
            @if (string.IsNullOrEmpty(Model?.ImageUrl))
            {
                <i class="fas fa-music" id="coverIcon"></i>
                <img id="playlistImg" src="" style="display:none; width: 100%; height: 100%; object-fit: cover;" />
            }
            else
            {
                <img id="playlistImg" src="@Model.ImageUrl" alt="Cover" />
            }
            <div class="upload-overlay">
                <i class="fas fa-pen"></i>
                <span style="font-size: 14px; margin-top: 5px;">Chọn ảnh</span>
            </div>
            <input type="file" id="fileInput" style="display: none;" accept="image/*" onchange="uploadImage(event)" />
        </div>

        <div class="playlist-info">
            <span class="sub-title">DANH SÁCH PHÁT</span>
            @* SỬA TÊN: Click trực tiếp vào chữ để sửa *@
            <h1 id="playlistTitle" contenteditable="true" spellcheck="false">@Model?.Name</h1>

            <div class="playlist-meta">
                <span class="user-name">@User.Identity?.Name</span>
                <span class="separator">•</span>
                <span id="songCountDisplay">@(Model?.PlaylistSongs?.Count ?? 0) bài hát</span>
            </div>

            @* SỬA MÔ TẢ: Click để sửa *@
            <div class="playlist-description">
                <p id="playlistDescription" contenteditable="true" spellcheck="false" class="description-text">
                    @if (string.IsNullOrEmpty(Model?.Description))
                    {
                        <span style="color: #666;">Nhấn để thêm mô tả...</span>
                    }
                    else
                    {
                        @Model.Description
                    }
                </p>
            </div>

            @* TRẠNG THÁI RIÊNG TƯ *@
            <div class="playlist-status">
                <button class="btn-privacy" onclick="togglePrivacy()">
                    @if (Model?.IsPrivate == true)
                    {
                        <i class="fas fa-lock"></i> <span>Riêng tư</span>
                    }
                    else
                    {
                        <i class="fas fa-globe"></i> <span>Công khai</span>
                    }
                </button>
            </div>
        </div>
    </div>

    <div class="playlist-body">
        <div class="action-bar">
            <button class="btn-play-all" id="playAllBtn" type="button">
                <i class="fas fa-play"></i> PHÁT TẤT CẢ
            </button>
            <button class="btn-add-song" id="toggleSearchBtn" type="button">
                <i class="fas fa-plus"></i> THÊM BÀI HÁT
            </button>
        </div>

        @* PHẦN TÌM KIẾM BÀI HÁT *@
        <div id="searchSection" style="display:none;" class="search-section">
            <hr class="section-divider" />
            <div class="search-input-box">
                <i class="fas fa-search"></i>
                <input type="text" id="songSearch" placeholder="Tìm kiếm bài hát để thêm vào danh sách..."
                    oninput="searchSongs(this.value)">
            </div>
            <div id="searchResults"></div>
        </div>

        <table class="song-table">
            <thead>
                <tr>
                    <th style="width: 50px">#</th>
                    <th>TIÊU ĐỀ</th>
                    <th>NGHỆ SĨ</th>
                    <th>ALBUM</th>
                    <th style="text-align: right; padding-right: 20px;"><i class="far fa-clock"></i></th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.PlaylistSongs != null && Model.PlaylistSongs.Any())
                {
                    var index = 1;
                    foreach (var ps in Model.PlaylistSongs)
                    {
                        @* CẬP NHẬT: Thêm class song-row và data-song-id để JavaScript nhận diện *@
                        <tr class="song-row" data-song-id="@ps.SongId" style="cursor: pointer;" onclick="playPlaylistSong(this)">
                            <td>@(index++)</td>
                            <td>
                                <div class="song-title-cell">
                                    <span>@ps.Song?.Name</span>
                                </div>
                            </td>
                            <td>@ps.Song?.Author</td>
                            <td>@ps.Song?.Album</td>
                            <td style="text-align: right; padding-right: 20px;">@(ps.Song == null ? string.Empty : (ps.Song.Duration.TotalHours >= 1 ? ps.Song.Duration.ToString(@"h\:mm\:ss") : ps.Song.Duration.ToString(@"mm\:ss")))</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="text-align:center; padding: 40px; color: #b3b3b3;">
                            Danh sách trống. Hãy thêm bài hát bên dưới!
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .playlist-page {
        padding: 30px;
        background: linear-gradient(180deg, #2d125c 0%, #09030e 60%, #050106 100%);
        min-height: 100vh;
        color: #f7f3ff;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .playlist-header {
        display: flex;
        gap: 24px;
        align-items: flex-end;
        padding-bottom: 30px;
    }

    .playlist-cover {
        width: 232px;
        height: 232px;
        background: linear-gradient(135deg, #4423a6, #8a4dff);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 80px;
        box-shadow: 0 24px 80px rgba(90, 54, 160, 0.35);
        overflow: hidden;
        border-radius: 28px;
    }

    .playlist-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .upload-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(29, 7, 63, 0.75);
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #f7f3ff;
        font-size: 24px;
    }

    .playlist-cover:hover .upload-overlay {
        display: flex;
    }

    .playlist-info .sub-title {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.14em;
        color: #d8c9ff;
        margin-bottom: 10px;
        text-transform: uppercase;
    }

    .playlist-info h1 {
        font-size: 72px;
        margin: 8px 0;
        font-weight: 900;
        color: #ffffff;
        outline: none;
        border-bottom: 2px solid transparent;
        transition: border 0.3s ease, color 0.3s ease;
    }

    .playlist-info h1:focus {
        border-bottom: 2px solid #b085ff;
    }

    .playlist-meta {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #c9beff;
        font-size: 14px;
    }

    .playlist-meta .separator {
        color: #6e5db8;
    }

    .playlist-description {
        margin-top: 15px;
    }

    .description-text {
        font-size: 14px;
        color: #b3b3b3;
        outline: none;
        padding: 8px;
        border-radius: 4px;
        border: 1px solid transparent;
        transition: all 0.3s;
        max-width: 400px;
    }

    .description-text:focus {
        border: 1px solid #1ed760;
        background: rgba(30, 215, 96, 0.1);
        color: white;
    }

    .playlist-status {
        margin-top: 12px;
    }

    .btn-privacy {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid #727272;
        color: white;
        padding: 8px 16px;
        border-radius: 50px;
        cursor: pointer;
        font-size: 12px;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-privacy:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    .action-bar {
        display: flex;
        gap: 20px;
        padding: 20px 0;
    }

    .btn-play-all {
        background: linear-gradient(135deg, #8f50ff, #5a13e8);
        border: none;
        border-radius: 50px;
        color: white;
        padding: 14px 32px;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 16px 30px rgba(92, 41, 189, 0.28);
    }

    .btn-play-all:hover {
        transform: scale(1.04);
        box-shadow: 0 20px 40px rgba(92, 41, 189, 0.35);
    }

    .btn-add-song {
        background: rgba(130, 78, 241, 0.08);
        border: 1px solid rgba(143, 80, 255, 0.5);
        color: #f7f3ff;
        padding: 8px 16px;
        border-radius: 50px;
        cursor: pointer;
        transition: background 0.2s ease, border-color 0.2s ease;
    }

    .btn-add-song:hover {
        background: rgba(143, 80, 255, 0.18);
        border-color: #8f50ff;
    }

    .search-input-box {
        display: flex;
        align-items: center;
        background: rgba(88, 40, 172, 0.18);
        padding: 8px 15px;
        border-radius: 8px;
        width: 300px;
    }

    .search-input-box input {
        background: transparent;
        border: none;
        color: #f7f3ff;
        margin-left: 10px;
        width: 100%;
        outline: none;
    }

    .song-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        background: rgba(58, 24, 126, 0.15);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
    }

    .song-table th {
        text-align: left;
        color: #c8b9ff;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 16px 12px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        background: rgba(41, 14, 102, 0.35);
    }

    .song-table tr:hover {
        background: rgba(155, 85, 255, 0.12);
    }

    .song-table td {
        padding: 14px 12px;
        color: #dcd3ff;
        font-size: 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .song-table tr:last-child td {
        border-bottom: none;
    }

    .song-title-cell span {
        color: #ffffff;
        font-weight: 600;
    }

    .btn-remove-song {
        background: transparent;
        border: none;
        color: #b3b3b3;
        cursor: pointer;
        padding: 4px 8px;
        margin-left: 10px;
        font-size: 16px;
        transition: color 0.2s;
        display: none;
    }

    .song-row:hover .btn-remove-song {
        display: inline;
        color: #ff4d4d;
    }

    .btn-remove-song:hover {
        color: #ff1744;
    }
</style>

@section Scripts {
    <script>
        console.log('=== PLAYLIST DETAILS SCRIPT STARTING ===');
        
        const playlistId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model?.Id));
        console.log('playlistId:', playlistId);

        function toggleSearch() {
            const section = document.getElementById('searchSection');
            section.style.display = section.style.display === 'none' ? 'block' : 'none';
        }

        function playAllSongs() {
            const songRows = document.querySelectorAll('.song-row');
            const playlistIds = [];

            songRows.forEach(row => {
                const id = row.getAttribute('data-song-id');
                if (id) {
                    playlistIds.push(id); // Keep as string
                }
            });

            if (playlistIds.length === 0) {
                alert("Playlist này chưa có bài hát nào!");
                return;
            }

            if (typeof openPlayer === "function") {
                openPlayer(playlistIds[0], playlistIds);

                const playerModal = document.getElementById('musicPlayerModal');
                if (playerModal) playerModal.style.display = 'flex';
            } else {
                alert("Hệ thống chưa nạp trình phát nhạc. Hãy kiểm tra lại file Layout hoặc site.js!");
            }
        }

        // Initialize button event listeners
        function initializeButtons() {
            console.log('initializeButtons called');
            const toggleSearchBtn = document.getElementById('toggleSearchBtn');
            const playAllBtn = document.getElementById('playAllBtn');

            console.log('toggleSearchBtn:', toggleSearchBtn);
            console.log('playAllBtn:', playAllBtn);

            if (toggleSearchBtn) {
                toggleSearchBtn.addEventListener('click', function() {
                    console.log('toggleSearchBtn clicked!');
                    toggleSearch();
                });
                console.log('toggleSearch listener attached');
            } else {
                console.error('toggleSearchBtn not found!');
            }
            
            if (playAllBtn) {
                playAllBtn.addEventListener('click', function() {
                    console.log('playAllBtn clicked!');
                    playAllSongs();
                });
                console.log('playAllSongs listener attached');
            } else {
                console.error('playAllBtn not found!');
            }
        }

        // Initialize when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initializeButtons);
        } else {
            initializeButtons();
        }

        // 1. Cập nhật tên Playlist
        try {
            const playlistTitle = document.getElementById('playlistTitle');
            if (playlistTitle) {
                playlistTitle.addEventListener('blur', async function () {
                    const newName = this.innerText.trim();
                    if (!newName) return;

                    try {
                        await fetch('/Playlist/UpdateName', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: playlistId, name: newName })
                        });
                    } catch (err) { console.error("Lỗi cập nhật tên:", err); }
                });
            }
        } catch (err) {
            console.error('Error setting up playlistTitle listener:', err);
        }

        // 1b. Cập nhật mô tả Playlist
        try {
            const playlistDesc = document.getElementById('playlistDescription');
            if (playlistDesc) {
                playlistDesc.addEventListener('blur', async function () {
                    const newDescription = this.innerText.trim();
                    const isPlaceholder = this.querySelector('span');
                    
                    // Nếu là placeholder text, xóa nó
                    if (isPlaceholder) {
                        isPlaceholder.remove();
                        this.innerText = newDescription || '';
                    }

                    try {
                        await fetch('/Playlist/UpdateDescription', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: playlistId, description: newDescription })
                        });
                    } catch (err) { console.error("Lỗi cập nhật mô tả:", err); }
                });
            }
        } catch (err) {
            console.error('Error setting up playlistDescription listener:', err);
        }

        // 2. Upload ảnh bìa
        async function uploadImage(event) {
            const file = event.target.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append('id', playlistId);
            formData.append('image', file);

            try {
                const response = await fetch('/Playlist/UpdateImage', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const data = await response.json();
                    const imgTag = document.getElementById('playlistImg');
                    const iconTag = document.getElementById('coverIcon');

                    if (iconTag) iconTag.style.display = 'none';
                    imgTag.src = data.newUrl;
                    imgTag.style.display = 'block';
                }
            } catch (err) { alert("Lỗi khi upload ảnh bìa!"); }
        }

        // 3. Tìm kiếm bài hát
        async function searchSongs(query) {
            console.log('searchSongs called with query:', query);
            const resultsDiv = document.getElementById('searchResults');
            if (query.length < 2) { resultsDiv.innerHTML = ''; return; }

            try {
                const url = `/Playlist/SearchSongs?query=${encodeURIComponent(query)}`;
                console.log('Fetching from:', url);
                const response = await fetch(url);
                const songs = await response.json();
                console.log('Songs returned:', songs);

                let html = '<div style="background: #282828; border-radius: 4px; padding: 10px; margin-top: 10px; max-width: 500px;">';
                if (songs.length === 0) {
                    html += '<p style="color: #b3b3b3; font-size: 14px; margin:0;">Không tìm thấy kết quả.</p>';
                } else {
                    songs.forEach(song => {
                        console.log('Adding song to results:', song);
                        html += `
                                <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; border-bottom: 1px solid #3e3e3e;">
                                    <div>
                                        <div style="font-weight: bold; color: white;">${song.name}</div>
                                        <div style="font-size: 12px; color: #b3b3b3;">${song.author}</div>
                                    </div>
                                    <button onclick="addToList('${song.id}')" 
                                            style="background: white; border: none; color: black; border-radius: 20px; padding: 5px 15px; cursor: pointer; font-weight:bold; font-size:12px;">
                                        Thêm
                                    </button>
                                </div>`;
                    });
                }
                html += '</div>';
                console.log('Setting HTML to resultsDiv, length:', html.length);
                resultsDiv.innerHTML = html;
                console.log('HTML set successfully');
            } catch (err) { 
                console.error('Error in searchSongs:', err); 
            }
        }

        // 4. Thêm bài hát vào danh sách
        async function addToList(songId) {
            console.log('addToList called with songId:', songId, 'playlistId:', playlistId);
            try {
                const payload = { playlistId: playlistId, songId: songId };
                console.log('Sending payload:', payload);
                
                const response = await fetch('/Playlist/AddSong', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                console.log('Response status:', response.status, 'ok:', response.ok);
                
                const text = await response.text();
                console.log('Response text:', text);
                
                if (response.ok) {
                    console.log('Success! Reloading page...');
                    location.reload();
                } else {
                    try {
                        const err = JSON.parse(text);
                        alert(err.message || "Không thể thêm bài hát.");
                    } catch (e) {
                        alert("Error: " + text);
                    }
                }
            } catch (err) { 
                console.error('Caught error:', err);
                alert("Error: " + err.message);
            }
        }

        function playPlaylistSong(row) {
            const songId = row?.getAttribute('data-song-id');
            if (!songId) return;

            const songRows = document.querySelectorAll('.song-row');
            const playlistIds = [];

            songRows.forEach(item => {
                const id = item.getAttribute('data-song-id');
                if (id) {
                    playlistIds.push(id); // Keep as string
                }
            });

            if (typeof openPlayer === "function") {
                openPlayer(songId, playlistIds); // Keep as string

                const playerModal = document.getElementById('musicPlayerModal');
                if (playerModal) playerModal.style.display = 'flex';
            } else {
                alert("Hệ thống chưa nạp trình phát nhạc. Hãy kiểm tra lại file Layout hoặc site.js!");
            }
        }

        // 6. Xóa bài hát khỏi Playlist
        async function removeSongFromPlaylist(songId, event) {
            event.stopPropagation();
            
            if (!confirm("Bạn chắc chắn muốn xóa bài hát này khỏi playlist?")) {
                return;
            }

            try {
                const response = await fetch(`/Playlist/RemoveSong?playlistId=${playlistId}&songId=${songId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.ok) {
                    // Xóa hàng từ bảng
                    const row = event.target.closest('.song-row');
                    row.remove();
                    
                    // Cập nhật số lượng bài hát
                    const songCount = document.querySelectorAll('.song-row').length;
                    document.getElementById('songCountDisplay').innerText = songCount + ' bài hát';
                    
                    // Nếu không còn bài hát nào, hiển thị thông báo
                    if (songCount === 0) {
                        location.reload();
                    }
                } else {
                    alert("Lỗi khi xóa bài hát!");
                }
            } catch (err) {
                console.error(err);
                alert("Có lỗi xảy ra!");
            }
        }

        // 7. Toggle trạng thái Riêng tư/Công khai
        async function togglePrivacy() {
            try {
                const response = await fetch(`/Playlist/TogglePrivacy?id=${playlistId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.ok) {
                    // Cập nhật giao diện nút
                    const btn = document.querySelector('.btn-privacy');
                    const icon = btn.querySelector('i');
                    const text = btn.querySelector('span');
                    
                    if (icon.classList.contains('fa-lock')) {
                        icon.classList.remove('fa-lock');
                        icon.classList.add('fa-globe');
                        text.textContent = 'Công khai';
                    } else {
                        icon.classList.remove('fa-globe');
                        icon.classList.add('fa-lock');
                        text.textContent = 'Riêng tư';
                    }
                } else {
                    alert("Lỗi khi cập nhật trạng thái!");
                }
            } catch (err) {
                console.error(err);
                alert("Có lỗi xảy ra!");
            }
        }
        
        console.log('=== PLAYLIST DETAILS SCRIPT FINISHED LOADING ===');
    </script>
}