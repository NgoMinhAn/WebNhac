@model IEnumerable<ServerWeb.Models.Song>
@{
    Layout = "_AdminLayout";
}

<div class="qunl-baihat-admin">
    <div class="qunl-baihat-title">Quản lý bài hát</div>

    <button class="qunl-baihat-addbtn" onclick="location.href='/Home/UploadSong'">Thêm bài hát</button>

    <div class="qunl-baihat-card">
        <div class="qunl-baihat-search">
            <span class="qunl-baihat-search-icon">
                <i class="fas fa-search"></i>
            </span>
            <input id="searchInput" type="text" placeholder="Tìm kiếm bài hát..." />
        </div>

        <div class="qunl-baihat-table-wrap">
            <table class="qunl-baihat-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên bài hát</th>
                        <th>Nghệ sĩ</th>
                        <th>Album</th>
                        <th>Thể loại</th>
                        <th>Thời lượng</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr data-song-id="@item.Id">
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                            <td>@item.Author</td>
                            <td>@item.Album</td>
                            <td>@item.Genre</td>
                            <td>@(item.Duration.TotalHours >= 1 ? item.Duration.ToString(@"h\:mm\:ss") : item.Duration.ToString(@"mm\:ss"))</td>
                            <td class="action-icons">
                                <i class="fas fa-edit edit-song-btn" style="cursor: pointer;"></i>
                                <i class="fas fa-trash delete-song-btn" style="cursor: pointer;"></i>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div id="deleteConfirmationOverlay" class="delete-overlay hidden">
        <div class="delete-popup">
            <h2>Xóa bài hát</h2>
            <p>Bạn có chắc muốn xóa bài hát này?</p>
            <div class="delete-actions">
                <button type="button" class="btn-cancel" onclick="closeDeletePopup()">Hủy</button>
                <button type="button" class="btn-delete" onclick="confirmDeleteSong()">Xóa</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var songToDelete = null;

        function initializePageHandlers() {
            // Search functionality
            var searchInput = document.getElementById('searchInput');
            if (searchInput) {
                searchInput.addEventListener('input', function (e) {
                    var value = e.target.value.toLowerCase();
                    var rows = document.querySelectorAll('.qunl-baihat-table tbody tr');
                    rows.forEach(function (row) {
                        var text = row.textContent.toLowerCase();
                        row.style.display = text.indexOf(value) > -1 ? '' : 'none';
                    });
                });
            }

            // Event delegation for edit and delete buttons
            document.addEventListener('click', function (e) {
                if (e.target.classList.contains('delete-song-btn')) {
                    const row = e.target.closest('tr');
                    if (row) {
                        const songId = row.getAttribute('data-song-id');
                        if (songId) {
                            deleteSong(songId);
                        }
                    }
                } else if (e.target.classList.contains('edit-song-btn')) {
                    const row = e.target.closest('tr');
                    if (row) {
                        const songId = row.getAttribute('data-song-id');
                        if (songId) {
                            editSong(songId);
                        }
                    }
                }
            });
        }

        function editSong(id) {
            console.log('Editing song:', id);
            window.location.href = '/Song/Edit/' + id;
        }

        function deleteSong(id) {
            console.log('Deleting song:', id);
            songToDelete = id;
            var overlay = document.getElementById('deleteConfirmationOverlay');
            if (overlay) {
                overlay.classList.remove('hidden');
            }
        }

        function closeDeletePopup() {
            songToDelete = null;
            var overlay = document.getElementById('deleteConfirmationOverlay');
            if (overlay) {
                overlay.classList.add('hidden');
            }
        }

        function confirmDeleteSong() {
            if (!songToDelete) return;
            
            console.log('Confirming delete for song:', songToDelete);

            fetch('/Home/DeleteSong', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ id: songToDelete })
            })
                .then(r => r.json())
                .then(data => {
                    console.log('Delete response:', data);
                    if (data.success) {
                        const row = document.querySelector('tr[data-song-id="' + songToDelete + '"]');
                        if (row) row.remove();
                        alert('Xóa bài hát thành công');
                        closeDeletePopup();
                    } else {
                        alert(data.message || 'Xóa thất bại.');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Lỗi mạng khi xóa bài hát. Vui lòng thử lại.');
                })
                .finally(() => {
                    closeDeletePopup();
                });
        }

        // Initialize when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initializePageHandlers);
        } else {
            initializePageHandlers();
        }
    </script>
}