@model ServerWeb.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="register-page">
  <div class="register-card">
    <h1>Đăng ký</h1>
    <p class="register-subtitle">Tạo tài khoản mới và tận hưởng âm nhạc bạn yêu thích</p>

    <form method="post" id="registerPageForm">
      <div class="register-field">
        <label for="Email">Địa chỉ e-mail</label>
        <input type="email" id="Email" name="Email" placeholder="vd: name@domain.com" asp-for="Email" required />
        <span asp-validation-for="Email" class="validation-error"></span>
      </div>

      <div class="register-field">
        <label for="Username">Tên người dùng</label>
        <input type="text" id="Username" name="Username" placeholder="Nhập tên người dùng" asp-for="Username" required />
        <span asp-validation-for="Username" class="validation-error"></span>
      </div>

      <div class="register-field">
        <label for="Password">Mật khẩu</label>
        <input type="password" id="Password" name="Password" placeholder="Nhập mật khẩu" asp-for="Password" required />
        <span asp-validation-for="Password" class="validation-error"></span>
      </div>

      <div class="register-field">
        <label for="ConfirmPassword">Xác nhận mật khẩu</label>
        <input type="password" id="ConfirmPassword" name="ConfirmPassword" placeholder="Xác nhận mật khẩu" required />
      </div>

      <button type="submit" class="btn-main">Tiếp tục</button>

      <div class="or-separator">Hoặc</div>

      <button type="button" class="btn-social phone">
        <span style="display:inline-flex;align-items:center;gap:8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 16.5C21 16.5 18 17.25 17.25 17.25C16.5 17.25 15.75 16.5 15.75 15.75C15.75 15 16.5 14.25 16.5 13.5C16.5 12.75 15.75 10.5 15.75 10.5C15.75 10.5 14.25 9 13.5 9C12.75 9 12 9.75 12 10.5C12 11.25 12.75 12.75 12.75 13.5C12.75 14.25 12 15 12 15C11.25 15.75 10.5 15.75 9.75 15.75C9 15.75 7.5 15 7.5 13.5C7.5 12 8.25 9.75 8.25 9.75C8.25 9.75 7.5 9 6.75 9C6 9 5.25 9.75 5.25 10.5C5.25 11.25 6 12.75 6 13.5C6 14.25 5.25 15 5.25 15C4.5 15.75 4.5 16.5 3.75 16.5C3 16.5 1.5 16.5 1.5 16.5" stroke="#152d31" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Đăng ký bằng số điện thoại</span>
      </button>
      <button type="button" class="btn-social facebook">
        <span style="display:inline-flex;align-items:center;gap:8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M22 12C22 6.48 17.52 2 12 2C6.48 2 2 6.48 2 12C2 17.02 5.66 21.13 10.44 21.88V14.89H7.9V12H10.44V9.84C10.44 7.33 11.93 5.9 14.2 5.9C15.25 5.9 16.34 6.1 16.34 6.1V8.58H15.01C13.7 8.58 13.38 9.29 13.38 10.02V12H16.2L15.79 14.89H13.38V21.88C18.16 21.13 22 17.02 22 12Z" fill="#0f3d5b"/></svg>Đăng ký bằng Facebook</span>
      </button>

      <p class="register-footer">
        Bạn đã có tài khoản? <a href="@Url.Action("Login", "Auth")">Đăng nhập</a>
      </p>

      @if (!ViewData.ModelState.IsValid)
      {
        <div class="error-box">
          @foreach (var modelState in ViewData.ModelState.Values)
          {
            @foreach (var error in modelState.Errors)
            {
              <p>@error.ErrorMessage</p>
            }
          }
        </div>
      }
    </form>
  </div>
</div>

<style>
.register-page {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #0b1220 0%, #1f3048 65%, #3b3f56 100%);
  padding: 24px;
}

.register-card {
  width: 100%;
  max-width: 420px;
  background: rgba(21, 27, 48, 0.95);
  border-radius: 20px;
  box-shadow: 0 16px 30px rgba(0, 0, 0, 0.45);
  padding: 30px;
  border: 1px solid rgba(255, 255, 255, 0.13);
  color: #f1f5fe;
}

.register-card h1 {
  margin: 0 0 10px;
  font-size: 30px;
  text-align: center;
  font-weight: 800;
}

.register-subtitle {
  text-align: center;
  margin-bottom: 22px;
  color: #bfcbdc;
  font-size: 14px;
}

.register-field {
  margin-bottom: 16px;
}

.register-field label {
  font-size: 13px;
  font-weight: 600;
  color: #b8c3dd;
  margin-bottom: 5px;
  display: block;
}

.register-field input {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.07);
  color: #ecf0ff;
  border-radius: 10px;
  font-size: 14px;
  outline: none;
}

.register-field input::placeholder {
  color: rgba(222, 232, 247, 0.7);
}

.btn-main {
  width: 100%;
  padding: 12px;
  border-radius: 28px;
  border: 0;
  font-size: 16px;
  font-weight: 700;
  color: #0f172a;
  background: linear-gradient(90deg, #ffaf26 0%, #ff7c31 100%);
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  margin-top: 8px;
}

.btn-main:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 18px rgba(255, 124, 49, 0.5);
}

.or-separator {
  margin: 20px 0 14px;
  color: #97a7c9;
  text-align: center;
  font-size: 13px;
}

.btn-social {
  width: 100%;
  border-radius: 26px;
  border: 0;
  font-size: 14px;
  font-weight: 700;
  padding: 10px;
  cursor: pointer;
  margin-bottom: 10px;
}

.btn-social.phone {
  background: linear-gradient(90deg, #8affd9 0%, #70f2c7 100%);
  color: #08262b;
  padding: 10px 14px;
  box-shadow: 0 4px 12px rgba(18, 129, 111, 0.26);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.btn-social.phone:hover {
  filter: brightness(1.03);
  transform: translateY(-1px);
}

.btn-social.facebook {
  background: linear-gradient(90deg, #8eccff 0%, #53b2ff 100%);
  color: #063554;
  padding: 10px 14px;
  box-shadow: 0 4px 12px rgba(12, 84, 141, 0.25);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.btn-social.facebook:hover {
  filter: brightness(1.03);
  transform: translateY(-1px);
}

.register-footer {
  margin-top: 14px;
  text-align: center;
  color: #b8c3dd;
  font-size: 14px;
}

.register-footer a {
  color: #84aaff;
  text-decoration: none;
  font-weight: 700;
}

.error-box {
  margin-top: 16px;
  padding: 12px;
  border-radius: 10px;
  background-color: rgba(255, 85, 85, 0.12);
  color: #ffc4c4;
  border: 1px solid rgba(255, 140, 140, 0.4);
}

.validation-error {
  margin-top: 4px;
  display: block;
  color: #ffb3b3;
  font-size: 12px;
}
</style>

<script>
  const form = document.getElementById('registerPageForm');
  form.addEventListener('submit', function (e) {
    const pass = document.getElementById('Password').value;
    const confirm = document.getElementById('ConfirmPassword').value;
    if (pass !== confirm) {
      e.preventDefault();
      alert('Mật khẩu không khớp!');
    }
  });
</script>
