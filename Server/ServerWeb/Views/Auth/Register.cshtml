@model ServerWeb.Controllers.RegisterViewModel
@{
  Layout = null;
  ViewData["Title"] = "Đăng ký";
}

<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Đăng ký - MusicWeb</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <style>
    * {
      box-sizing: border-box;
      font-family: 'Segoe UI', sans-serif;
    }

    body {
      margin: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: #121212;
      color: white;
    }

    .register-card {
      width: 100%;
      max-width: 420px;
      background: #1d212b;
      padding: 35px;
      border-radius: 24px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
      position: relative;
    }

    h1 {
      font-size: 24px;
      text-align: center;
      margin-bottom: 25px;
      font-weight: 700;
    }

    .form-group {
      margin-bottom: 15px;
    }

    label {
      display: block;
      margin-bottom: 5px;
      font-size: 13px;
      color: #cfd4da;
    }

    input {
      width: 100%;
      padding: 12px;
      border-radius: 10px;
      border: 1px solid #3e4451;
      background: #2a2f3b;
      color: white;
      font-size: 14px;
      outline: none;
    }

    input:focus {
      border-color: #ff9f43;
    }

    .btn-submit {
      width: 100%;
      padding: 14px;
      background: #ff9f43;
      color: #000;
      border: none;
      border-radius: 30px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 15px;
    }

    .separator {
      text-align: center;
      margin: 20px 0;
      color: #7a828c;
      font-size: 13px;
    }

    .btn-social {
      width: 100%;
      padding: 10px;
      border-radius: 30px;
      border: none;
      margin-bottom: 10px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 13px;
    }

    .btn-phone {
      background: #b2fcf0;
      color: #004d40;
    }

    .btn-facebook {
      background: #8cd4ff;
      color: #003354;
    }

    .footer-link {
      text-align: center;
      margin-top: 20px;
      font-size: 14px;
    }

    .footer-link a {
      color: #ff9f43;
      text-decoration: none;
      font-weight: 700;
    }
  </style>
</head>

<body>

  <div class="register-card">
    <h1>Đăng ký để bắt đầu thưởng thức âm nhạc</h1>

    <form asp-action="Register" asp-controller="Auth" method="post" id="regForm">

      <div class="form-group">
        <label>Địa chỉ e-mail</label>
        <input type="email" asp-for="Email" placeholder="vd: name@domain.com" required />
      </div>

      <div class="form-group">
        <label>Tên đăng nhập</label>
        <input type="text" asp-for="Username" placeholder="Tên hiển thị của bạn" required />
      </div>

      <div class="form-group">
        <label>Mật khẩu</label>
        <input type="password" asp-for="Password" id="txtPassword" placeholder="Nhập mật khẩu" required />
      </div>

      <div class="form-group">
        <label>Xác nhận mật khẩu</label>
        <input type="password" name="ConfirmPassword" id="txtConfirm" placeholder="Nhập lại mật khẩu" required />
      </div>

      <button type="submit" class="btn-submit">Đăng ký ngay</button>

      <div class="separator">Hoặc</div>

      <button type="button" class="btn-social btn-phone"><i class="fas fa-mobile-alt"></i> Đăng ký bằng số điện
        thoại</button>
      <button type="button" class="btn-social btn-facebook"><i class="fab fa-facebook"></i> Đăng ký bằng
        Facebook</button>

      <div class="footer-link">
        Bạn đã có tài khoản? <a href="/Auth/Login">Đăng nhập</a>
      </div>
    </form>
  </div>

  <script>
    // Kiểm tra mật khẩu khớp nhau trước khi submit
    document.getElementById('regForm').addEventListener('submit', function (e) {
      const p1 = document.getElementById('txtPassword').value;
      const p2 = document.getElementById('txtConfirm').value;
      if (p1 !== p2) {
        e.preventDefault();
        alert("Mật khẩu xác nhận không khớp!");
      }
    });
  </script>
</body>

</html>