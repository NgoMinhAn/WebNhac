@model ServerWeb.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
.login-page {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: radial-gradient(circle at 20% 20%, #3d414a 0%, #22262d 55%, #17191d 100%);
    color: #fff;
}

.login-card {
    width: 100%;
    max-width: 420px;
    background: #23272f;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.35);
    padding: 36px 30px;
}

.login-card h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 30px;
    font-weight: 700;
    margin-bottom: 6px;
    text-align: center;
}

.login-card .subtitle {
    color: #cbd4de;
    text-align: center;
    margin-bottom: 24px;
    font-size: 14px;
}

.login-card .form-group { margin-bottom: 18px; }
.login-card label {
    color: #c2c7d6;
    font-weight: 600;
    font-size: 13px;
    margin-bottom: 8px;
    display: block;
}

.login-card input {
    width: 100%;
    padding: 12px 13px;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.08);
    color: #fff;
    border-radius: 12px;
    font-size: 15px;
    outline: none;
}

.login-card input::placeholder { color: rgba(255,255,255,0.65); }

.primary-button {
    width: 100%;
    padding: 12px;
    margin-top: 6px;
    border: none;
    border-radius: 22px;
    background: linear-gradient(90deg, #ffba4b 0%, #ff8c42 100%);
    color: #1a1a1a;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    box-shadow: 0 10px 20px rgba(255, 140, 66, 0.25);
}

.social-login {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 14px;
}

.social-button {
    border: none;
    border-radius: 20px;
    padding: 11px;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
}

.phone-button { background: #b8fff6; color: #152d31; }
.fb-button { background: #7dd2ff; color: #0f3d5b; }

.or-divider { text-align: center; margin: 14px 0 8px; color: #bfc9d4; }

.footer-link { text-align: center; margin-top: 16px; color: #d8dde6; }
.footer-link a { color: #fff; font-weight: 700; text-decoration: none; }

.validation-summary { background: rgba(210,50,50,0.18); color: #ffb3b3; padding: 10px; border-radius: 10px; margin-bottom: 12px; font-size: 13px; }


</style>

<div class="login-page">
    <div class="login-card">
        <h2>Chào mừng đến với âm nhạc</h2>
        <div class="subtitle">Đăng nhập để tiếp tục</div>

        <form method="post">
            <div class="form-group">
                <label for="Email">E-mail hoặc tên người dùng</label>
                <input asp-for="Email" type="text" id="Email" name="Email" placeholder="Nhập email hoặc tên người dùng" required />
                <span asp-validation-for="Email" class="field-validation-error" style="color:#ffb3b3;font-size:12px;"></span>
            </div>
            
            <div class="form-group">
                <label for="Password">Mật khẩu</label>
                <input asp-for="Password" type="password" id="Password" name="Password" placeholder="Nhập mật khẩu" required />
                <span asp-validation-for="Password" class="field-validation-error" style="color:#ffb3b3;font-size:12px;"></span>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <p>@error.ErrorMessage</p>
                        }
                    }
                </div>
            }

            <button type="submit" class="primary-button">Tiếp tục</button>
        </form>

        <div class="or-divider">Hoặc</div>
        <div class="social-login">
            <button type="button" class="social-button phone-button">
                <span style="display:inline-flex;align-items:center;gap:8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 16.5C21 16.5 18 17.25 17.25 17.25C16.5 17.25 15.75 16.5 15.75 15.75C15.75 15 16.5 14.25 16.5 13.5C16.5 12.75 15.75 10.5 15.75 10.5C15.75 10.5 14.25 9 13.5 9C12.75 9 12 9.75 12 10.5C12 11.25 12.75 12.75 12.75 13.5C12.75 14.25 12 15 12 15C11.25 15.75 10.5 15.75 9.75 15.75C9 15.75 7.5 15 7.5 13.5C7.5 12 8.25 9.75 8.25 9.75C8.25 9.75 7.5 9 6.75 9C6 9 5.25 9.75 5.25 10.5C5.25 11.25 6 12.75 6 13.5C6 14.25 5.25 15 5.25 15C4.5 15.75 4.5 16.5 3.75 16.5C3 16.5 1.5 16.5 1.5 16.5" stroke="#152d31" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Đăng nhập bằng số điện thoại</span>
            </button>
            <button type="button" class="social-button fb-button">
                <span style="display:inline-flex;align-items:center;gap:8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M22 12C22 6.48 17.52 2 12 2C6.48 2 2 6.48 2 12C2 17.02 5.66 21.13 10.44 21.88V14.89H7.9V12H10.44V9.84C10.44 7.33 11.93 5.9 14.2 5.9C15.25 5.9 16.34 6.1 16.34 6.1V8.58H15.01C13.7 8.58 13.38 9.29 13.38 10.02V12H16.2L15.79 14.89H13.38V21.88C18.16 21.13 22 17.02 22 12Z" fill="#0f3d5b"/></svg>Đăng nhập bằng Facebook</span>
            </button>
        </div>

        <div class="footer-link">Bạn chưa có tài khoản? <a href="@Url.Action("Register", "Auth")">Đăng ký ngay</a></div>
    </div>
</div>
